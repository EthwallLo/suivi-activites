<Window x:Class="MonTableurApp.Views.EditProjetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Modifier le produit"
        Width="820"
        Height="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.Resources>
        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFE"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DataGridSurfaceBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="26"/>
            <Setter Property="Padding" Value="22"/>
        </Style>

        <Style x:Key="EditorLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="4,0,0,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
        </Style>

        <Style x:Key="EditorTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource SearchInputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SearchInputForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SearchInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource InfoCardAccentBrush}"/>
                                <Setter TargetName="Border" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EditorComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource SearchInputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SearchInputForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SearchInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="18,11"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTitleBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SummaryCardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SummaryCardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource MenuButtonHoverBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource MenuButtonPressedBackgroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DeleteActionButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryActionButtonStyle}">
            <Setter Property="Foreground" Value="#B65D72"/>
            <Setter Property="Background" Value="#FFF3F7"/>
            <Setter Property="BorderBrush" Value="#F2C7D5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource SectionCardStyle}"
                Padding="24"
                Background="{DynamicResource InfoCardBackgroundBrush}"
                BorderBrush="{DynamicResource InfoCardBorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Width="66"
                        Height="66"
                        Background="{DynamicResource LogoChipBackgroundBrush}"
                        BorderBrush="{DynamicResource LogoChipBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="22"
                        VerticalAlignment="Top">
                    <TextBlock Text="â˜…"
                               FontSize="28"
                               Foreground="{DynamicResource InfoCardAccentBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1"
                            Margin="16,2,0,0">
                    <TextBlock Text="Modifier le produit"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTitleBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="0,18,0,18"
                Style="{StaticResource SectionCardStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource SectionCardStyle}"
                            Background="#FFFDFE"
                            Padding="20"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="IdentitÃ© du projet"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTitleBrush}"/>

                            <Grid Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="NumÃ©ro projet" Style="{StaticResource EditorLabelStyle}"/>
                                    <TextBox Text="{Binding EditableProjet.NumeroProjet, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource EditorTextBoxStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Nom produit" Style="{StaticResource EditorLabelStyle}"/>
                                    <TextBox Text="{Binding EditableProjet.NomProduit, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource EditorTextBoxStyle}"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Famille de produits" Style="{StaticResource EditorLabelStyle}"/>
                                    <ComboBox ItemsSource="{Binding ViewModel.FamillesProduit}"
                                              SelectedItem="{Binding EditableProjet.FamilleProduit, UpdateSourceTrigger=PropertyChanged}"
                                              Style="{StaticResource EditorComboBoxStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Client" Style="{StaticResource EditorLabelStyle}"/>
                                    <ComboBox ItemsSource="{Binding ViewModel.Clients}"
                                              SelectedItem="{Binding EditableProjet.Client, UpdateSourceTrigger=PropertyChanged}"
                                              Style="{StaticResource EditorComboBoxStyle}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Style="{StaticResource SectionCardStyle}"
                            Background="#FFFDFE"
                            Padding="20"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Suivi mÃ©tier"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTitleBrush}"/>

                            <Grid Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Demandeur" Style="{StaticResource EditorLabelStyle}"/>
                                    <ComboBox ItemsSource="{Binding ViewModel.Demandeurs}"
                                              SelectedItem="{Binding EditableProjet.Demandeur, UpdateSourceTrigger=PropertyChanged}"
                                              Style="{StaticResource EditorComboBoxStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Type dâ€™activitÃ©" Style="{StaticResource EditorLabelStyle}"/>
                                    <ComboBox ItemsSource="{Binding ViewModel.TypesActivite}"
                                              SelectedItem="{Binding EditableProjet.TypeActivite, UpdateSourceTrigger=PropertyChanged}"
                                              Style="{StaticResource EditorComboBoxStyle}"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Statut" Style="{StaticResource EditorLabelStyle}"/>
                                    <ComboBox ItemsSource="{Binding ViewModel.Statuts}"
                                              SelectedItem="{Binding EditableProjet.Statut, UpdateSourceTrigger=PropertyChanged}"
                                              Style="{StaticResource EditorComboBoxStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Dossier racine" Style="{StaticResource EditorLabelStyle}"/>
                                    <TextBox Text="{Binding EditableProjet.DossierRacine, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource EditorTextBoxStyle}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2"
                            Style="{StaticResource SectionCardStyle}"
                            Background="#FFFDFE"
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="Dates &amp; notes"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTitleBrush}"/>

                            <Grid Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Date de dÃ©but" Style="{StaticResource EditorLabelStyle}"/>
                                    <TextBox Text="{Binding EditableProjet.DateDebut, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource EditorTextBoxStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="8,0,8,0">
                                    <TextBlock Text="Date prÃ©visionnelle" Style="{StaticResource EditorLabelStyle}"/>
                                    <TextBox Text="{Binding EditableProjet.DatePrevisionnelle, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource EditorTextBoxStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                    <TextBlock Text="Date de fin" Style="{StaticResource EditorLabelStyle}"/>
                                    <TextBox Text="{Binding EditableProjet.DateFin, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource EditorTextBoxStyle}"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel Margin="0,16,0,0">
                                <TextBlock Text="Commentaires" Style="{StaticResource EditorLabelStyle}"/>
                                <TextBox MinHeight="112"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         VerticalContentAlignment="Top"
                                         Text="{Binding EditableProjet.Commentaires, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource EditorTextBoxStyle}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Width="182"
                    HorizontalAlignment="Left"
                    Content="Supprimer le produit"
                    Style="{StaticResource DeleteActionButtonStyle}"
                    Click="Delete_Click"/>

            <Button Grid.Column="1"
                    Width="110"
                    Margin="12,0,0,0"
                    Content="Annuler"
                    Style="{StaticResource PrimaryActionButtonStyle}"
                    Click="Cancel_Click"/>

            <Button Grid.Column="2"
                    Width="134"
                    Margin="12,0,0,0"
                    Content="Enregistrer"
                    Style="{StaticResource PrimaryActionButtonStyle}"
                    Click="Save_Click"/>
        </Grid>
    </Grid>
</Window>
