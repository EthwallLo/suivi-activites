<Window x:Class="MonTableurApp.Views.EditProjetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="Modifier le produit"
        Width="820"
        Height="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.Resources>
        <Style x:Key="InvisibleRepeatButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Rectangle Fill="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CuteThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                Background="{DynamicResource ScrollThumbBrush}"
                                CornerRadius="8"
                                Margin="1"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource ScrollThumbHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Border x:Name="TrackBorder"
                                    Background="{DynamicResource ScrollTrackBrush}"
                                    CornerRadius="8"/>
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton x:Name="DecreaseButton"
                                                  Style="{StaticResource InvisibleRepeatButtonStyle}"
                                                  Command="ScrollBar.PageLeftCommand"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource CuteThumbStyle}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton x:Name="IncreaseButton"
                                                  Style="{StaticResource InvisibleRepeatButtonStyle}"
                                                  Command="ScrollBar.PageRightCommand"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="TrackBorder" Property="Height" Value="12"/>
                                <Setter TargetName="TrackBorder" Property="Margin" Value="0,10,0,2"/>
                                <Setter Property="Height" Value="16"/>
                            </Trigger>
                            <Trigger Property="Orientation" Value="Vertical">
                                <Setter TargetName="TrackBorder" Property="Width" Value="12"/>
                                <Setter TargetName="TrackBorder" Property="Margin" Value="2,0,0,0"/>
                                <Setter Property="Width" Value="16"/>
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="True"/>
                                <Setter TargetName="DecreaseButton" Property="Command" Value="ScrollBar.PageUpCommand"/>
                                <Setter TargetName="IncreaseButton" Property="Command" Value="ScrollBar.PageDownCommand"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFE"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DataGridSurfaceBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="26"/>
            <Setter Property="Padding" Value="22"/>
        </Style>

        <Style x:Key="EditorLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="4,0,0,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
        </Style>

        <Style x:Key="EditorTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource SearchInputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SearchInputForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SearchInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource InfoCardAccentBrush}"/>
                                <Setter TargetName="Border" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EditorComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource SearchInputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SearchInputForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SearchInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="18">
                                <Grid Margin="{TemplateBinding Padding}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <ContentPresenter Margin="0,0,10,0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="&#x25BE;"
                                               FontSize="15"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <ToggleButton Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          Opacity="0.01"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>

                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="White"
                                        BorderBrush="{DynamicResource SearchInputBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Margin="0,6,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="260">
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource MenuButtonHoverBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource InfoCardAccentBrush}"/>
                                <Setter TargetName="ComboBorder" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                CornerRadius="10"
                                Margin="4">
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource DataGridRowHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource DataGridRowSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EditorDateFieldBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SearchInputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SearchInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="MinHeight" Value="42"/>
        </Style>

        <Style x:Key="FolderBrowseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="{DynamicResource DataGridAltRowBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SearchInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTitleBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource DataGridRowHoverBrush}"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource SummaryCardBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource DataGridRowSelectedBrush}"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource PrimaryTitleBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GridCalendarPopupToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ButtonChrome"
                                Width="24"
                                Height="24"
                                Background="{DynamicResource DataGridAltRowBrush}"
                                BorderBrush="{DynamicResource SearchInputBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="CalendarIcon"
                                       Text="&#xE787;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="12"
                                       Foreground="{TemplateBinding Foreground}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource DataGridRowHoverBrush}"/>
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{DynamicResource SummaryCardBorderBrush}"/>
                                <Setter TargetName="CalendarIcon" Property="Foreground" Value="{DynamicResource PrimaryTitleBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource DataGridRowSelectedBrush}"/>
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{DynamicResource PrimaryTitleBrush}"/>
                                <Setter TargetName="CalendarIcon" Property="Foreground" Value="{DynamicResource PrimaryTitleBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GridCalendarNavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="NavButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavButtonBorder" Property="Background" Value="{DynamicResource DataGridRowHoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTitleBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="NavButtonBorder" Property="Background" Value="{DynamicResource DataGridRowSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GridCalendarHeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource DataGridAltRowBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SearchInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTitleBrush}"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="HeaderButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderButtonBorder" Property="Background" Value="{DynamicResource DataGridRowHoverBrush}"/>
                                <Setter TargetName="HeaderButtonBorder" Property="BorderBrush" Value="{DynamicResource SummaryCardBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="HeaderButtonBorder" Property="Background" Value="{DynamicResource DataGridRowSelectedBrush}"/>
                                <Setter TargetName="HeaderButtonBorder" Property="BorderBrush" Value="{DynamicResource PrimaryTitleBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GridCalendarButtonStyle" TargetType="CalendarButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource SearchInputForegroundBrush}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="MinWidth" Value="42"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CalendarButton">
                        <Border x:Name="MonthBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Margin="{TemplateBinding Margin}"
                                MinWidth="{TemplateBinding MinWidth}"
                                MinHeight="{TemplateBinding MinHeight}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MonthBorder" Property="Background" Value="{DynamicResource DataGridRowHoverBrush}"/>
                                <Setter TargetName="MonthBorder" Property="BorderBrush" Value="{DynamicResource SummaryCardBorderBrush}"/>
                                <Setter TargetName="MonthBorder" Property="BorderThickness" Value="1"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTitleBrush}"/>
                            </Trigger>
                            <Trigger Property="HasSelectedDays" Value="True">
                                <Setter TargetName="MonthBorder" Property="Background" Value="{DynamicResource DataGridRowSelectedBrush}"/>
                                <Setter TargetName="MonthBorder" Property="BorderBrush" Value="{DynamicResource PrimaryTitleBrush}"/>
                                <Setter TargetName="MonthBorder" Property="BorderThickness" Value="1"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTitleBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.32"/>
                            </Trigger>
                            <Trigger Property="IsInactive" Value="True">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GridCalendarDayButtonStyle" TargetType="primitives:CalendarDayButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource SearchInputForegroundBrush}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="primitives:CalendarDayButton">
                        <Border x:Name="DayBorder"
                                MinWidth="30"
                                MinHeight="28"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DayBorder" Property="Background" Value="{DynamicResource DataGridRowHoverBrush}"/>
                                <Setter TargetName="DayBorder" Property="BorderBrush" Value="{DynamicResource SummaryCardBorderBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTitleBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="DayBorder" Property="Background" Value="{DynamicResource DataGridRowSelectedBrush}"/>
                                <Setter TargetName="DayBorder" Property="BorderBrush" Value="{DynamicResource PrimaryTitleBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTitleBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.28"/>
                            </Trigger>
                            <Trigger Property="IsToday" Value="True">
                                <Setter TargetName="DayBorder" Property="BorderBrush" Value="{DynamicResource SummaryCardBorderBrush}"/>
                                <Setter TargetName="DayBorder" Property="Background" Value="{DynamicResource DataGridAltRowBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsInactive" Value="True">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                            <Trigger Property="IsBlackedOut" Value="True">
                                <Setter Property="IsHitTestVisible" Value="False"/>
                                <Setter Property="Focusable" Value="False"/>
                                <Setter Property="Opacity" Value="0.3"/>
                                <Setter TargetName="DayBorder" Property="Background" Value="Transparent"/>
                                <Setter TargetName="DayBorder" Property="BorderBrush" Value="Transparent"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GridCalendarItemStyle" TargetType="primitives:CalendarItem">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="{DynamicResource SearchInputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="primitives:CalendarItem">
                        <ControlTemplate.Resources>
                            <DataTemplate x:Key="DayTitleTemplate">
                                <TextBlock Text="{Binding}"
                                           Margin="0,0,0,6"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </DataTemplate>
                        </ControlTemplate.Resources>

                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18"
                                Padding="6">
                            <Grid x:Name="PART_Root">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0"
                                      Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Button x:Name="PART_PreviousButton"
                                            Grid.Column="0"
                                            Width="30"
                                            Height="30"
                                            Margin="0,0,8,0"
                                            Style="{StaticResource GridCalendarNavButtonStyle}"
                                            Content="&#xE76B;"
                                            FontFamily="Segoe MDL2 Assets"
                                            FontSize="12"/>

                                    <Button x:Name="PART_HeaderButton"
                                            Grid.Column="1"
                                            HorizontalAlignment="Stretch"
                                            Style="{StaticResource GridCalendarHeaderButtonStyle}"/>

                                    <Button x:Name="PART_NextButton"
                                            Grid.Column="2"
                                            Width="30"
                                            Height="30"
                                            Margin="8,0,0,0"
                                            Style="{StaticResource GridCalendarNavButtonStyle}"
                                            Content="&#xE76C;"
                                            FontFamily="Segoe MDL2 Assets"
                                            FontSize="12"/>
                                </Grid>

                                <Grid x:Name="PART_MonthView"
                                      Grid.Row="1"
                                      Margin="2,0,2,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                </Grid>

                                <Grid x:Name="PART_YearView"
                                      Grid.Row="1"
                                      Margin="6,4,6,6"
                                      Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                </Grid>

                                <Border x:Name="PART_DisabledVisual"
                                        Grid.RowSpan="2"
                                        Background="#80FFFFFF"
                                        CornerRadius="18"
                                        Visibility="Collapsed"/>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="PART_DisabledVisual" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding DisplayMode, RelativeSource={RelativeSource AncestorType=Calendar}}"
                                         Value="{x:Static CalendarMode.Month}">
                                <Setter TargetName="PART_MonthView" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="PART_YearView" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding DisplayMode, RelativeSource={RelativeSource AncestorType=Calendar}}"
                                         Value="{x:Static CalendarMode.Year}">
                                <Setter TargetName="PART_MonthView" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="PART_YearView" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding DisplayMode, RelativeSource={RelativeSource AncestorType=Calendar}}"
                                         Value="{x:Static CalendarMode.Decade}">
                                <Setter TargetName="PART_MonthView" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="PART_YearView" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GridCalendarStyle" TargetType="Calendar">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Language" Value="fr-FR"/>
            <Setter Property="FirstDayOfWeek" Value="Monday"/>
            <Setter Property="Background" Value="{DynamicResource SearchInputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource SearchInputForegroundBrush}"/>
            <Setter Property="CalendarButtonStyle" Value="{StaticResource GridCalendarButtonStyle}"/>
            <Setter Property="CalendarDayButtonStyle" Value="{StaticResource GridCalendarDayButtonStyle}"/>
            <Setter Property="CalendarItemStyle" Value="{StaticResource GridCalendarItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Calendar">
                        <StackPanel x:Name="PART_Root"
                                    Background="{TemplateBinding Background}">
                            <primitives:CalendarItem x:Name="PART_CalendarItem"
                                                     Background="{TemplateBinding Background}"
                                                     BorderBrush="{TemplateBinding BorderBrush}"
                                                     BorderThickness="{TemplateBinding BorderThickness}"
                                                     Style="{TemplateBinding CalendarItemStyle}"/>
                        </StackPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GridCalendarPopupStyle" TargetType="Popup">
            <Setter Property="AllowsTransparency" Value="True"/>
            <Setter Property="PopupAnimation" Value="Fade"/>
            <Setter Property="StaysOpen" Value="False"/>
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="18,11"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTitleBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SummaryCardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SummaryCardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource MenuButtonHoverBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource MenuButtonPressedBackgroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DeleteActionButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryActionButtonStyle}">
            <Setter Property="Foreground" Value="#B65D72"/>
            <Setter Property="Background" Value="#FFF3F7"/>
            <Setter Property="BorderBrush" Value="#F2C7D5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource SectionCardStyle}"
                Padding="24"
                Background="{DynamicResource InfoCardBackgroundBrush}"
                BorderBrush="{DynamicResource InfoCardBorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Width="66"
                        Height="66"
                        Background="{DynamicResource LogoChipBackgroundBrush}"
                        BorderBrush="{DynamicResource LogoChipBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="22"
                        VerticalAlignment="Top">
                    <TextBlock Text="&#x2605;"
                               FontSize="28"
                               Foreground="{DynamicResource InfoCardAccentBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1"
                            Margin="16,0,0,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="Modifier le produit"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTitleBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="0,18,0,18"
                Style="{StaticResource SectionCardStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource SectionCardStyle}"
                            Background="#FFFDFE"
                            Padding="20"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Identité du projet"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTitleBrush}"/>

                            <Grid Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Numéro projet" Style="{StaticResource EditorLabelStyle}"/>
                                    <TextBox Text="{Binding EditableProjet.NumeroProjet, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource EditorTextBoxStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Nom produit" Style="{StaticResource EditorLabelStyle}"/>
                                    <TextBox Text="{Binding EditableProjet.NomProduit, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource EditorTextBoxStyle}"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Famille de produits" Style="{StaticResource EditorLabelStyle}"/>
                                    <ComboBox ItemsSource="{Binding ViewModel.FamillesProduit}"
                                              SelectedItem="{Binding EditableProjet.FamilleProduit, UpdateSourceTrigger=PropertyChanged}"
                                              Style="{StaticResource EditorComboBoxStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Client" Style="{StaticResource EditorLabelStyle}"/>
                                    <ComboBox ItemsSource="{Binding ViewModel.Clients}"
                                              SelectedItem="{Binding EditableProjet.Client, UpdateSourceTrigger=PropertyChanged}"
                                              Style="{StaticResource EditorComboBoxStyle}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Style="{StaticResource SectionCardStyle}"
                            Background="#FFFDFE"
                            Padding="20"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Suivi métier"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTitleBrush}"/>

                            <Grid Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Demandeur" Style="{StaticResource EditorLabelStyle}"/>
                                    <ComboBox ItemsSource="{Binding ViewModel.Demandeurs}"
                                              SelectedItem="{Binding EditableProjet.Demandeur, UpdateSourceTrigger=PropertyChanged}"
                                              Style="{StaticResource EditorComboBoxStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Type d’activité" Style="{StaticResource EditorLabelStyle}"/>
                                    <ComboBox ItemsSource="{Binding ViewModel.TypesActivite}"
                                              SelectedItem="{Binding EditableProjet.TypeActivite, UpdateSourceTrigger=PropertyChanged}"
                                              Style="{StaticResource EditorComboBoxStyle}"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Statut" Style="{StaticResource EditorLabelStyle}"/>
                                    <ComboBox ItemsSource="{Binding ViewModel.Statuts}"
                                              SelectedItem="{Binding EditableProjet.Statut, UpdateSourceTrigger=PropertyChanged}"
                                              Style="{StaticResource EditorComboBoxStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Dossier racine" Style="{StaticResource EditorLabelStyle}"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBox Text="{Binding EditableProjet.DossierRacine, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="14,7"
                                                 MinHeight="42"
                                                 Style="{StaticResource EditorTextBoxStyle}"/>

                                        <Button Grid.Column="1"
                                                Margin="8,0,0,0"
                                                Style="{StaticResource FolderBrowseButtonStyle}"
                                                Click="BrowseDossierRacine_Click">
                                            <TextBlock Text="&#xE838;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="14"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       RenderTransformOrigin="0.5,0.5">
                                                <TextBlock.RenderTransform>
                                                    <RotateTransform Angle="270"/>
                                                </TextBlock.RenderTransform>
                                            </TextBlock>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2"
                            Style="{StaticResource SectionCardStyle}"
                            Background="#FFFDFE"
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="Dates &amp; notes"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTitleBrush}"/>

                            <Grid Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Date de début" Style="{StaticResource EditorLabelStyle}"/>
                                    <Border Style="{StaticResource EditorDateFieldBorderStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{Binding EditableProjet.DateDebutValue, StringFormat={}{0:dd/MM/yyyy}, TargetNullValue=Choisir}"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource SearchInputForegroundBrush}"/>

                                            <ToggleButton x:Name="EditDateDebutToggle"
                                                          Grid.Column="1"
                                                          Margin="10,0,0,0"
                                                          Style="{StaticResource GridCalendarPopupToggleStyle}"/>

                                            <Popup Placement="Bottom"
                                                   PlacementTarget="{Binding ElementName=EditDateDebutToggle}"
                                                   IsOpen="{Binding IsChecked, ElementName=EditDateDebutToggle, Mode=TwoWay}"
                                                   Style="{StaticResource GridCalendarPopupStyle}">
                                                <Border Background="White"
                                                        BorderBrush="{DynamicResource SearchInputBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="20"
                                                        Padding="12"
                                                        Margin="0,8,0,0">
                                                    <Calendar DataContext="{Binding EditableProjet}"
                                                              Style="{StaticResource GridCalendarStyle}"
                                                              Tag="{Binding ElementName=EditDateDebutToggle}"
                                                              SelectedDate="{Binding EditableProjet.DateDebutValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              SelectedDatesChanged="CalendarPopup_SelectedDatesChanged"/>
                                                </Border>
                                            </Popup>
                                        </Grid>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="8,0,8,0">
                                    <TextBlock Text="Date prévisionnelle" Style="{StaticResource EditorLabelStyle}"/>
                                    <Border Style="{StaticResource EditorDateFieldBorderStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{Binding EditableProjet.DatePrevisionnelleValue, StringFormat={}{0:dd/MM/yyyy}, TargetNullValue=Choisir}"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource SearchInputForegroundBrush}"/>

                                            <ToggleButton x:Name="EditDatePrevisionnelleToggle"
                                                          Grid.Column="1"
                                                          Margin="10,0,0,0"
                                                          Style="{StaticResource GridCalendarPopupToggleStyle}"/>

                                            <Popup Placement="Bottom"
                                                   PlacementTarget="{Binding ElementName=EditDatePrevisionnelleToggle}"
                                                   DataContext="{Binding EditableProjet}"
                                                   IsOpen="{Binding IsChecked, ElementName=EditDatePrevisionnelleToggle, Mode=TwoWay}"
                                                   Opened="ConstrainedCalendarPopup_Opened"
                                                   Style="{StaticResource GridCalendarPopupStyle}">
                                                <Border Background="White"
                                                        BorderBrush="{DynamicResource SearchInputBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="20"
                                                        Padding="12"
                                                        Margin="0,8,0,0">
                                                    <Calendar DataContext="{Binding EditableProjet}"
                                                              Style="{StaticResource GridCalendarStyle}"
                                                              Tag="{Binding ElementName=EditDatePrevisionnelleToggle}"
                                                              DisplayDateStart="{Binding EditableProjet.DateDebutValue}"
                                                              SelectedDate="{Binding EditableProjet.DatePrevisionnelleValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              SelectedDatesChanged="CalendarPopup_SelectedDatesChanged"/>
                                                </Border>
                                            </Popup>
                                        </Grid>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                    <TextBlock Text="Date de fin" Style="{StaticResource EditorLabelStyle}"/>
                                    <Border Style="{StaticResource EditorDateFieldBorderStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{Binding EditableProjet.DateFinValue, StringFormat={}{0:dd/MM/yyyy}, TargetNullValue=Choisir}"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource SearchInputForegroundBrush}"/>

                                            <ToggleButton x:Name="EditDateFinToggle"
                                                          Grid.Column="1"
                                                          Margin="10,0,0,0"
                                                          Style="{StaticResource GridCalendarPopupToggleStyle}"/>

                                            <Popup Placement="Bottom"
                                                   PlacementTarget="{Binding ElementName=EditDateFinToggle}"
                                                   DataContext="{Binding EditableProjet}"
                                                   IsOpen="{Binding IsChecked, ElementName=EditDateFinToggle, Mode=TwoWay}"
                                                   Opened="ConstrainedCalendarPopup_Opened"
                                                   Style="{StaticResource GridCalendarPopupStyle}">
                                                <Border Background="White"
                                                        BorderBrush="{DynamicResource SearchInputBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="20"
                                                        Padding="12"
                                                        Margin="0,8,0,0">
                                                    <Calendar DataContext="{Binding EditableProjet}"
                                                              Style="{StaticResource GridCalendarStyle}"
                                                              Tag="{Binding ElementName=EditDateFinToggle}"
                                                              DisplayDateStart="{Binding EditableProjet.DateDebutValue}"
                                                              SelectedDate="{Binding EditableProjet.DateFinValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              SelectedDatesChanged="CalendarPopup_SelectedDatesChanged"/>
                                                </Border>
                                            </Popup>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <StackPanel Margin="0,16,0,0">
                                <TextBlock Text="Commentaires" Style="{StaticResource EditorLabelStyle}"/>
                                <TextBox MinHeight="112"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         VerticalContentAlignment="Top"
                                         Text="{Binding EditableProjet.Commentaires, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource EditorTextBoxStyle}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Width="182"
                    HorizontalAlignment="Left"
                    Content="Supprimer le produit"
                    Style="{StaticResource DeleteActionButtonStyle}"
                    Click="Delete_Click"/>

            <Button Grid.Column="1"
                    Width="110"
                    Margin="12,0,0,0"
                    Content="Annuler"
                    Style="{StaticResource PrimaryActionButtonStyle}"
                    Click="Cancel_Click"/>

            <Button Grid.Column="2"
                    Width="134"
                    Margin="12,0,0,0"
                    Content="Enregistrer"
                    Style="{StaticResource PrimaryActionButtonStyle}"
                    Click="Save_Click"/>
        </Grid>
    </Grid>
</Window>
