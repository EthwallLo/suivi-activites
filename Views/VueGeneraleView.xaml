<UserControl x:Class="MonTableurApp.Views.VueGeneraleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="SummaryCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,14,0"/>
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="Background" Value="#FFF2F8"/>
            <Setter Property="BorderBrush" Value="#F5C8DD"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FFE6F1"/>
            <Setter Property="Foreground" Value="#8D4D79"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="MinHeight" Value="46"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFF5FA"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFE8F4"/>
                    <Setter Property="Foreground" Value="#6E4967"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Vue d'ensemble"
                       Foreground="#8A4E78"
                       FontSize="24"
                       FontWeight="SemiBold"/>
            <TextBlock Text="Tout le tableau est éditable."
                       Margin="0,6,0,18"
                       Foreground="#A07A94"
                       FontSize="14"/>

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource SummaryCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Tous les projets"
                                   Foreground="#A07A94"
                                   FontSize="13"/>
                        <TextBlock Text="{Binding TotalProjets}"
                                   Margin="0,10,0,0"
                                   Foreground="#8A4E78"
                                   FontSize="30"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Style="{StaticResource SummaryCardStyle}"
                        Background="#FFF4D8"
                        BorderBrush="#F1D89B">
                    <StackPanel>
                        <TextBlock Text="En cours"
                                   Foreground="#B5843E"
                                   FontSize="13"/>
                        <TextBlock Text="{Binding StatutsEnCours}"
                                   Margin="0,10,0,0"
                                   Foreground="#A8712A"
                                   FontSize="30"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource SummaryCardStyle}"
                        Background="#EAF8F5"
                        BorderBrush="#B8E4D9">
                    <StackPanel>
                        <TextBlock Text="Rapports en cours"
                                   Foreground="#4B9A8A"
                                   FontSize="13"/>
                        <TextBlock Text="{Binding RapportsEnCours}"
                                   Margin="0,10,0,0"
                                   Foreground="#3D897A"
                                   FontSize="30"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3"
                        Style="{StaticResource SummaryCardStyle}"
                        Margin="0"
                        Background="#F0EEFF"
                        BorderBrush="#D3CEF8">
                    <StackPanel>
                        <TextBlock Text="Faits"
                                   Foreground="#7269C6"
                                   FontSize="13"/>
                        <TextBlock Text="{Binding ProjetsFaits}"
                                   Margin="0,10,0,0"
                                   Foreground="#625AB1"
                                   FontSize="30"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>

        <Border Grid.Row="1"
                Background="#FFFFFF"
                BorderBrush="#F3D9E7"
                BorderThickness="1"
                CornerRadius="24"
                Padding="10">
            <DataGrid ItemsSource="{Binding Projets}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="True"
                      CanUserDeleteRows="True"
                      GridLinesVisibility="None"
                      HeadersVisibility="Column"
                      RowHeaderWidth="0"
                      BorderThickness="0"
                      Background="Transparent"
                      AlternatingRowBackground="#FFF9FC"
                      RowBackground="White"
                      SelectionMode="Single"
                      SelectionUnit="FullRow">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Numéro projet"
                                        Binding="{Binding NumeroProjet}"
                                        Width="120"/>
                    <DataGridTextColumn Header="Nom produit"
                                        Binding="{Binding NomProduit}"
                                        Width="170"/>

                    <DataGridComboBoxColumn Header="Client"
                                            SelectedItemBinding="{Binding Client}"
                                            Width="120"
                                            ItemsSource="{Binding DataContext.Clients, RelativeSource={RelativeSource AncestorType=Window}}"/>

                    <DataGridComboBoxColumn Header="Demandeur"
                                            SelectedItemBinding="{Binding Demandeur}"
                                            Width="120"
                                            ItemsSource="{Binding DataContext.Demandeurs, RelativeSource={RelativeSource AncestorType=Window}}"/>

                    <DataGridComboBoxColumn Header="Type d'activité"
                                            SelectedItemBinding="{Binding TypeActivite}"
                                            Width="150"
                                            ItemsSource="{Binding DataContext.TypesActivite, RelativeSource={RelativeSource AncestorType=Window}}"/>

                    <DataGridTextColumn Header="Dossier racine"
                                        Binding="{Binding DossierRacine}"
                                        Width="260"/>

                    <DataGridComboBoxColumn Header="Statut"
                                            SelectedItemBinding="{Binding Statut}"
                                            Width="190"
                                            ItemsSource="{Binding DataContext.Statuts, RelativeSource={RelativeSource AncestorType=Window}}"/>

                    <DataGridTextColumn Header="Date début"
                                        Binding="{Binding DateDebut}"
                                        Width="110"/>
                    <DataGridTextColumn Header="Date prévisionnelle"
                                        Binding="{Binding DatePrevisionnelle}"
                                        Width="130"/>
                    <DataGridTextColumn Header="Date fin"
                                        Binding="{Binding DateFin}"
                                        Width="110"/>
                    <DataGridTextColumn Header="Commentaires"
                                        Binding="{Binding Commentaires}"
                                        Width="210"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
