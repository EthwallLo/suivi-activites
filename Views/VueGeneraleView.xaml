<UserControl x:Class="MonTableurApp.Views.VueGeneraleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="SummaryCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="18,16"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="MinHeight" Value="106"/>
            <Setter Property="Background" Value="{DynamicResource SummaryCardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SummaryCardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SummaryCardButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="18,16"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource SummaryCardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SummaryCardBorderBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="MinHeight" Value="106"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CardBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource MenuButtonHoverBorderBrush}"/>
                                <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource MenuButtonHoverBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource DataGridRowSelectedBrush}"/>
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource PrimaryTitleBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedTextBoxStyle" TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource SearchInputForegroundBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SearchInputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SearchInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ExportButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource ThemeButtonForegroundBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ThemeButtonBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ExportBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ExportBorder" Property="Background" Value="{DynamicResource MenuButtonHoverBackgroundBrush}"/>
                                <Setter TargetName="ExportBorder" Property="BorderBrush" Value="{DynamicResource MenuButtonHoverBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ExportBorder" Property="Background" Value="{DynamicResource MenuButtonPressedBackgroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource DataGridHeaderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource DataGridHeaderForegroundBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="MinHeight" Value="46"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DataGridRowHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DataGridRowSelectedBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource DataGridSelectionForegroundBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DataGridRowSelectedBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource DataGridSelectionForegroundBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InvisibleRepeatButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Rectangle Fill="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CuteThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                Background="{DynamicResource ScrollThumbBrush}"
                                CornerRadius="8"
                                Margin="1"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource ScrollThumbHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Border x:Name="TrackBorder"
                                    Background="{DynamicResource ScrollTrackBrush}"
                                    CornerRadius="8"/>
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton x:Name="DecreaseButton"
                                                  Style="{StaticResource InvisibleRepeatButtonStyle}"
                                                  Command="ScrollBar.PageLeftCommand"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource CuteThumbStyle}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton x:Name="IncreaseButton"
                                                  Style="{StaticResource InvisibleRepeatButtonStyle}"
                                                  Command="ScrollBar.PageRightCommand"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="TrackBorder" Property="Height" Value="12"/>
                                <Setter TargetName="TrackBorder" Property="Margin" Value="0,10,0,2"/>
                                <Setter Property="Height" Value="16"/>
                            </Trigger>
                            <Trigger Property="Orientation" Value="Vertical">
                                <Setter TargetName="TrackBorder" Property="Width" Value="12"/>
                                <Setter TargetName="TrackBorder" Property="Margin" Value="2,0,0,0"/>
                                <Setter Property="Width" Value="16"/>
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="True"/>
                                <Setter TargetName="DecreaseButton" Property="Command" Value="ScrollBar.PageUpCommand"/>
                                <Setter TargetName="IncreaseButton" Property="Command" Value="ScrollBar.PageDownCommand"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CenteredTextColumnElementStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="CenteredTextColumnEditingStyle" TargetType="TextBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CenteredComboCellTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="GridComboBoxToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="22"/>
                                </Grid.ColumnDefinitions>

                                <ContentPresenter Grid.Column="0"
                                                  Margin="10,0,0,0"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="&#x25BE;"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GridComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource SearchInputForegroundBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SearchInputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SearchInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Style="{StaticResource GridComboBoxToggleButtonStyle}">
                                <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </ToggleButton>

                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="White"
                                        BorderBrush="{DynamicResource SearchInputBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Margin="0,4,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="260">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleButton" Property="BorderBrush" Value="{DynamicResource SummaryCardBorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource GridComboBoxStyle}">
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="MinWidth" Value="136"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                CornerRadius="8"
                                Margin="4">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource DataGridRowHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource DataGridRowSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Vue d'ensemble"
                           Foreground="{DynamicResource PrimaryTitleBrush}"
                           FontSize="24"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Content="Exporter vers Excel"
                        Style="{StaticResource ExportButtonStyle}"
                        Click="ExporterTableau_Click"
                        VerticalAlignment="Center"/>
            </Grid>

            <Grid Margin="0,18,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1.45*"/>
                </Grid.ColumnDefinitions>

                <Button Click="TousProjets_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SummaryCardButtonStyle}">
                            <Setter Property="Foreground" Value="{DynamicResource SummaryValueBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAllFilterActive}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource DataGridRowSelectedBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryTitleBrush}"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Grid VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Tous les projets"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                   Opacity="0.82"
                                   FontSize="14"/>
                        <TextBlock Grid.Row="1"
                                   Text="{Binding TotalProjets}"
                                   Margin="0,8,0,0"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                   FontSize="32"
                                   FontWeight="Bold"/>
                    </Grid>
                </Button>

                <Button Grid.Column="1"
                        Click="EnCours_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SummaryCardButtonStyle}">
                            <Setter Property="Background" Value="{DynamicResource SummaryWarmBackgroundBrush}"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource SummaryWarmBorderBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource SummaryWarmForegroundBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsInProgressFilterActive}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource DataGridRowSelectedBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryTitleBrush}"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Grid VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="En cours"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                   Opacity="0.82"
                                   FontSize="14"/>
                        <TextBlock Grid.Row="1"
                                   Text="{Binding StatutsEnCours}"
                                   Margin="0,8,0,0"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                   FontSize="32"
                                   FontWeight="Bold"/>
                    </Grid>
                </Button>

                <Button Grid.Column="2"
                        Click="Rapports_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SummaryCardButtonStyle}">
                            <Setter Property="Background" Value="{DynamicResource SummaryMintBackgroundBrush}"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource SummaryMintBorderBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource SummaryMintForegroundBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsReportsFilterActive}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource DataGridRowSelectedBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryTitleBrush}"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Grid VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Rapports en cours"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                   Opacity="0.82"
                                   FontSize="14"/>
                        <TextBlock Grid.Row="1"
                                   Text="{Binding RapportsEnCours}"
                                   Margin="0,8,0,0"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                   FontSize="32"
                                   FontWeight="Bold"/>
                    </Grid>
                </Button>

                <Button Grid.Column="3"
                        Click="Faits_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SummaryCardButtonStyle}">
                            <Setter Property="Background" Value="{DynamicResource SummaryLavenderBackgroundBrush}"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource SummaryLavenderBorderBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource SummaryLavenderForegroundBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDoneFilterActive}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource DataGridRowSelectedBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryTitleBrush}"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Grid VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Terminés"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                   Opacity="0.82"
                                   FontSize="14"/>
                        <TextBlock Grid.Row="1"
                                   Text="{Binding ProjetsFaits}"
                                   Margin="0,8,0,0"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                   FontSize="32"
                                   FontWeight="Bold"/>
                    </Grid>
                </Button>

                <Border Grid.Column="4"
                        Margin="0"
                        Padding="14"
                        MinHeight="88"
                        CornerRadius="18"
                        Background="{DynamicResource SearchCardBackgroundBrush}"
                        BorderBrush="{DynamicResource SearchCardBorderBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Recherche produit"
                                   Foreground="{DynamicResource SummaryLabelBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>

                        <Grid Grid.Row="1"
                              Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="148"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox Grid.Column="0"
                                      Style="{StaticResource SearchComboBoxStyle}"
                                      ItemsSource="{Binding ProjetSearchFields}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Key"
                                      SelectedValue="{Binding SelectedProjetSearchFieldKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBox Grid.Column="2"
                                     Style="{StaticResource RoundedTextBoxStyle}"
                                     Text="{Binding SearchNomProduit, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </StackPanel>

        <Border Grid.Row="1"
                Background="#FFFFFF"
                BorderBrush="{DynamicResource DataGridSurfaceBorderBrush}"
                BorderThickness="1"
                CornerRadius="24"
                Padding="10">
            <DataGrid ItemsSource="{Binding ProjetsView}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="True"
                      GridLinesVisibility="None"
                      HeadersVisibility="Column"
                      RowHeaderWidth="0"
                      BorderThickness="0"
                      Background="Transparent"
                      AlternatingRowBackground="{DynamicResource DataGridAltRowBrush}"
                      RowBackground="White"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Numéro projet"
                                        Binding="{Binding NumeroProjet}"
                                        Width="1.15*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource CenteredTextColumnElementStyle}">
                                <Setter Property="Margin" Value="6,0,0,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                        <DataGridTextColumn.EditingElementStyle>
                            <Style TargetType="TextBox" BasedOn="{StaticResource CenteredTextColumnEditingStyle}">
                                <Setter Property="Padding" Value="6,0,0,0"/>
                            </Style>
                        </DataGridTextColumn.EditingElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Nom produit"
                                        Binding="{Binding NomProduit}"
                                        ElementStyle="{StaticResource CenteredTextColumnElementStyle}"
                                        EditingElementStyle="{StaticResource CenteredTextColumnEditingStyle}"
                                        Width="1.35*"/>

                    <DataGridTemplateColumn Header="Client"
                                            Width="0.95*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Client}"
                                               Style="{StaticResource CenteredComboCellTextStyle}"
                                               MaxWidth="86"/>
                                    <TextBlock Text="&#x25BE;"
                                               Margin="2,0,0,0"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.Clients, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          Style="{StaticResource GridComboBoxStyle}"
                                          SelectedItem="{Binding Client, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Demandeur"
                                            Width="0.95*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Demandeur}"
                                               Style="{StaticResource CenteredComboCellTextStyle}"
                                               MaxWidth="86"/>
                                    <TextBlock Text="&#x25BE;"
                                               Margin="2,0,0,0"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.Demandeurs, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          Style="{StaticResource GridComboBoxStyle}"
                                          SelectedItem="{Binding Demandeur, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Type d'activité"
                                            Width="1.35*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding TypeActivite}"
                                               Style="{StaticResource CenteredComboCellTextStyle}"
                                               MaxWidth="136"/>
                                    <TextBlock Text="&#x25BE;"
                                               Margin="2,0,0,0"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.TypesActivite, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          Style="{StaticResource GridComboBoxStyle}"
                                          SelectedItem="{Binding TypeActivite, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Dossier racine"
                                        Binding="{Binding DossierRacine}"
                                        ElementStyle="{StaticResource CenteredTextColumnElementStyle}"
                                        EditingElementStyle="{StaticResource CenteredTextColumnEditingStyle}"
                                        Width="2.6*"/>

                    <DataGridTemplateColumn Header="Statut"
                                            Width="1.65*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Statut}"
                                               Style="{StaticResource CenteredComboCellTextStyle}"
                                               MaxWidth="156"/>
                                    <TextBlock Text="&#x25BE;"
                                               Margin="2,0,0,0"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.Statuts, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          Style="{StaticResource GridComboBoxStyle}"
                                          SelectedItem="{Binding Statut, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Date début"
                                        Binding="{Binding DateDebut}"
                                        ElementStyle="{StaticResource CenteredTextColumnElementStyle}"
                                        EditingElementStyle="{StaticResource CenteredTextColumnEditingStyle}"
                                        Width="0.95*"/>
                    <DataGridTextColumn Header="Date prévisionnelle"
                                        Binding="{Binding DatePrevisionnelle}"
                                        ElementStyle="{StaticResource CenteredTextColumnElementStyle}"
                                        EditingElementStyle="{StaticResource CenteredTextColumnEditingStyle}"
                                        Width="1.1*"/>
                    <DataGridTextColumn Header="Date fin"
                                        Binding="{Binding DateFin}"
                                        ElementStyle="{StaticResource CenteredTextColumnElementStyle}"
                                        EditingElementStyle="{StaticResource CenteredTextColumnEditingStyle}"
                                        Width="0.95*"/>
                    <DataGridTextColumn Header="Commentaires"
                                        Binding="{Binding Commentaires}"
                                        ElementStyle="{StaticResource CenteredTextColumnElementStyle}"
                                        EditingElementStyle="{StaticResource CenteredTextColumnEditingStyle}"
                                        Width="1.7*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
