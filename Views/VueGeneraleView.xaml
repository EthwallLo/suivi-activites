<UserControl x:Class="MonTableurApp.Views.VueGeneraleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="SummaryCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,14,0"/>
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="Background" Value="#F4EEE3"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#E6DDD1"/>
            <Setter Property="Foreground" Value="#2D3A37"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F9F5EE"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EADFCF"/>
                    <Setter Property="Foreground" Value="#24312F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Resume rapide"
                       Foreground="#263532"
                       FontSize="24"
                       FontWeight="SemiBold"/>
            <TextBlock Text="Les projets restent modifiables directement dans le tableau, avec un recap visuel en haut."
                       Margin="0,6,0,18"
                       Foreground="#667671"
                       FontSize="14"/>

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource SummaryCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Tous les projets"
                                   Foreground="#667671"
                                   FontSize="13"/>
                        <TextBlock Text="{Binding TotalProjets}"
                                   Margin="0,10,0,0"
                                   Foreground="#22312E"
                                   FontSize="30"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Style="{StaticResource SummaryCardStyle}"
                        Background="#E1EFE8">
                    <StackPanel>
                        <TextBlock Text="En cours"
                                   Foreground="#45635B"
                                   FontSize="13"/>
                        <TextBlock Text="{Binding ProjetsEnCours}"
                                   Margin="0,10,0,0"
                                   Foreground="#214640"
                                   FontSize="30"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource SummaryCardStyle}"
                        Background="#F8E9CF">
                    <StackPanel>
                        <TextBlock Text="En attente"
                                   Foreground="#8A6531"
                                   FontSize="13"/>
                        <TextBlock Text="{Binding ProjetsEnAttente}"
                                   Margin="0,10,0,0"
                                   Foreground="#7A5729"
                                   FontSize="30"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3"
                        Style="{StaticResource SummaryCardStyle}"
                        Margin="0"
                        Background="#E2E7F3">
                    <StackPanel>
                        <TextBlock Text="Termines"
                                   Foreground="#55627E"
                                   FontSize="13"/>
                        <TextBlock Text="{Binding ProjetsTermines}"
                                   Margin="0,10,0,0"
                                   Foreground="#3C4B69"
                                   FontSize="30"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>

        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#E8DFD3"
                BorderThickness="1"
                CornerRadius="24"
                Padding="10">
            <DataGrid ItemsSource="{Binding Projets}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="True"
                      CanUserDeleteRows="True"
                      GridLinesVisibility="None"
                      HeadersVisibility="Column"
                      RowHeaderWidth="0"
                      BorderThickness="0"
                      Background="Transparent"
                      AlternatingRowBackground="#FBF8F2"
                      RowBackground="White"
                      SelectionMode="Single"
                      SelectionUnit="FullRow">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Projet"
                                        Binding="{Binding NumeroProjet}"
                                        Width="110"/>
                    <DataGridTextColumn Header="Produit"
                                        Binding="{Binding NomProduit}"
                                        Width="170"/>

                    <DataGridComboBoxColumn Header="Client"
                                            SelectedItemBinding="{Binding Client}"
                                            Width="140"
                                            ItemsSource="{Binding DataContext.Clients, RelativeSource={RelativeSource AncestorType=Window}}"/>

                    <DataGridComboBoxColumn Header="Demandeur"
                                            SelectedItemBinding="{Binding Demandeur}"
                                            Width="140"
                                            ItemsSource="{Binding DataContext.Demandeurs, RelativeSource={RelativeSource AncestorType=Window}}"/>

                    <DataGridComboBoxColumn Header="Type"
                                            SelectedItemBinding="{Binding TypeActivite}"
                                            Width="130"
                                            ItemsSource="{Binding DataContext.TypesActivite, RelativeSource={RelativeSource AncestorType=Window}}"/>

                    <DataGridComboBoxColumn Header="Statut"
                                            SelectedItemBinding="{Binding Statut}"
                                            Width="130"
                                            ItemsSource="{Binding DataContext.Statuts, RelativeSource={RelativeSource AncestorType=Window}}"/>

                    <DataGridTextColumn Header="Debut"
                                        Binding="{Binding DateDebut}"
                                        Width="110"/>
                    <DataGridTextColumn Header="Prevision"
                                        Binding="{Binding DatePrevisionnelle}"
                                        Width="110"/>
                    <DataGridTextColumn Header="Fin"
                                        Binding="{Binding DateFin}"
                                        Width="110"/>
                    <DataGridTextColumn Header="Commentaires"
                                        Binding="{Binding Commentaires}"
                                        Width="2*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
