<UserControl x:Class="MonTableurApp.Views.VueSuiviEssaisView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="InvisibleRepeatButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Rectangle Fill="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CuteThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                Background="{DynamicResource ScrollThumbBrush}"
                                CornerRadius="8"
                                Margin="1"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource ScrollThumbHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Border x:Name="TrackBorder"
                                    Background="{DynamicResource ScrollTrackBrush}"
                                    CornerRadius="8"/>
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton x:Name="DecreaseButton"
                                                  Style="{StaticResource InvisibleRepeatButtonStyle}"
                                                  Command="ScrollBar.PageLeftCommand"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource CuteThumbStyle}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton x:Name="IncreaseButton"
                                                  Style="{StaticResource InvisibleRepeatButtonStyle}"
                                                  Command="ScrollBar.PageRightCommand"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="TrackBorder" Property="Height" Value="12"/>
                                <Setter TargetName="TrackBorder" Property="Margin" Value="0,10,0,2"/>
                                <Setter Property="Height" Value="24"/>
                            </Trigger>
                            <Trigger Property="Orientation" Value="Vertical">
                                <Setter TargetName="TrackBorder" Property="Width" Value="12"/>
                                <Setter TargetName="TrackBorder" Property="Margin" Value="2,0,0,0"/>
                                <Setter Property="Width" Value="16"/>
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="True"/>
                                <Setter TargetName="DecreaseButton" Property="Command" Value="ScrollBar.PageUpCommand"/>
                                <Setter TargetName="IncreaseButton" Property="Command" Value="ScrollBar.PageDownCommand"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedTextBoxStyle" TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource SearchInputForegroundBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SearchInputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SearchInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DataGridSurfaceBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="24"/>
        </Style>

        <Style x:Key="EssaiStatusComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource SearchInputForegroundBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SearchInputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SearchInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="14">
                                <Grid Margin="{TemplateBinding Padding}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <ContentPresenter Margin="0,0,8,0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="&#x25BE;"
                                               FontSize="15"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <ToggleButton Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          Opacity="0.01"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>

                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   PopupAnimation="Slide">
                                <Border Background="White"
                                        BorderBrush="{DynamicResource SearchInputBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Margin="0,6,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="260">
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource MenuButtonHoverBorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EssaiResultatComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource EssaiStatusComboBoxStyle}">
            <Setter Property="MinWidth" Value="88"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                CornerRadius="10"
                                Margin="4">
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource DataGridRowHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource DataGridRowSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProjetListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemCard"
                                Padding="14"
                                Background="{DynamicResource SummaryCardBackgroundBrush}"
                                BorderBrush="{DynamicResource SummaryCardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="18">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemCard" Property="Background" Value="{DynamicResource MenuButtonHoverBackgroundBrush}"/>
                                <Setter TargetName="ItemCard" Property="BorderBrush" Value="{DynamicResource MenuButtonHoverBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemCard" Property="Background" Value="{DynamicResource DataGridRowSelectedBrush}"/>
                                <Setter TargetName="ItemCard" Property="BorderBrush" Value="{DynamicResource PrimaryTitleBrush}"/>
                                <Setter TargetName="ItemCard" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MetricPillStyle" TargetType="Border">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Background" Value="{DynamicResource SummaryCardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SummaryCardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="MetricFilterButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CardBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CardBorder" Property="Opacity" Value="0.84"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EssaiProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="8"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="Foreground" Value="{DynamicResource InfoCardAccentBrush}"/>
            <Setter Property="Background" Value="{DynamicResource DataGridRowHoverBrush}"/>
        </Style>

        <Style x:Key="ProductManageButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SummaryCardBorderBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SummaryCardBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTitleBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource MenuButtonHoverBackgroundBrush}"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource MenuButtonHoverBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="EmptySelectionTemplate">
            <Border Style="{StaticResource SectionCardStyle}"
                    Padding="38">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="Choisis un produit"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTitleBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Sélectionne un projet à gauche pour renseigner le statut de chaque essai."
                               Margin="0,12,0,0"
                               FontSize="15"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="SelectedProjetTemplate">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Style="{StaticResource SectionCardStyle}"
                        Padding="26">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="{Binding NomProduit}"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTitleBrush}"/>
                                <TextBlock Text="Infos du produit et actions rapides"
                                           Margin="0,6,0,0"
                                           FontSize="13"
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Style="{StaticResource ProductManageButtonStyle}"
                                    Click="ModifierProduit_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Modifier le produit"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Margin="8,0,0,0"
                                               Text="✎"
                                               FontSize="14"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <WrapPanel Margin="0,12,0,0">
                            <Border Style="{StaticResource MetricPillStyle}">
                                <StackPanel>
                                    <TextBlock Text="Numéro projet"
                                               FontSize="12"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <TextBlock Text="{Binding NumeroProjet}"
                                               Margin="0,4,0,0"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTitleBrush}"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource MetricPillStyle}">
                                <StackPanel>
                                    <TextBlock Text="Client"
                                               FontSize="12"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <TextBlock Text="{Binding Client}"
                                               Margin="0,4,0,0"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTitleBrush}"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource MetricPillStyle}">
                                <StackPanel>
                                    <TextBlock Text="Projet"
                                               FontSize="12"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <TextBlock Text="{Binding Statut}"
                                               Margin="0,4,0,0"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTitleBrush}"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>

                        <WrapPanel Margin="0,18,0,0">
                            <Button Click="EssaisATraiter_Click">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource MetricFilterButtonStyle}">
                                        <Setter Property="Background" Value="{DynamicResource SummaryMintBackgroundBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource SummaryMintBorderBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.IsEssaiToProcessFilterActive, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource DataGridRowSelectedBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryTitleBrush}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel>
                                    <TextBlock Text="À traiter"
                                               FontSize="12"
                                               Foreground="{DynamicResource SummaryMintForegroundBrush}"/>
                                    <TextBlock Text="{Binding DataContext.EssaisSelectionATraiter, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               Margin="0,4,0,0"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource SummaryMintForegroundBrush}"/>
                                </StackPanel>
                            </Button>

                            <Button Click="EssaisEnCours_Click">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource MetricFilterButtonStyle}">
                                        <Setter Property="Background" Value="{DynamicResource SummaryWarmBackgroundBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource SummaryWarmBorderBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.IsEssaiInProgressFilterActive, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource DataGridRowSelectedBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryTitleBrush}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel>
                                    <TextBlock Text="Essais en cours"
                                               FontSize="12"
                                               Foreground="{DynamicResource SummaryWarmForegroundBrush}"/>
                                    <TextBlock Text="{Binding DataContext.EssaisSelectionEnCours, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               Margin="0,4,0,0"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource SummaryWarmForegroundBrush}"/>
                                </StackPanel>
                            </Button>
                            
                            <Button Click="EssaisTermines_Click">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource MetricFilterButtonStyle}">
                                        <Setter Property="Background" Value="{DynamicResource SummaryLavenderBackgroundBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource SummaryLavenderBorderBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.IsEssaiDoneFilterActive, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource DataGridRowSelectedBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryTitleBrush}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel>
                                    <TextBlock Text="Essais terminés"
                                               FontSize="12"
                                               Foreground="{DynamicResource SummaryLavenderForegroundBrush}"/>
                                    <TextBlock Text="{Binding DataContext.EssaisSelectionTermines, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               Margin="0,4,0,0"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource SummaryLavenderForegroundBrush}"/>
                                </StackPanel>
                            </Button>

                            
                            <Border Style="{StaticResource MetricPillStyle}">
                                <StackPanel>
                                    <TextBlock Text="Total des essais"
                                               FontSize="12"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <TextBlock Text="{Binding DataContext.EssaisSelectionTotal, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               Margin="0,4,0,0"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource SummaryValueBrush}"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,18,0,0"
                        Style="{StaticResource SectionCardStyle}"
                        Padding="22">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="Statut par essai"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTitleBrush}"/>
                        </StackPanel>

                        <ScrollViewer Grid.Row="1"
                                      Margin="0,18,0,0"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="0,8,0,0">
                                <StackPanel>
                                    <TextBlock Text="Pré-qualification"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTitleBrush}"/>

                                    <ItemsControl ItemsSource="{Binding DataContext.EssaisPreQualificationFiltres, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  Margin="0,14,0,0">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="4"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,12,12"
                                                        MinHeight="138"
                                                        Padding="14"
                                                        Background="{DynamicResource SearchCardBackgroundBrush}"
                                                        BorderBrush="{DynamicResource SearchCardBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="20">
                                                    <StackPanel>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock Text="{Binding NomEssai}"
                                                                       TextWrapping="Wrap"
                                                                       FontSize="15"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource PrimaryTitleBrush}"/>

                                                            <Ellipse Grid.Column="1"
                                                                     Width="12"
                                                                     Height="12"
                                                                     Margin="10,2,0,0"
                                                                     Fill="{Binding CouleurIndicateurEtat}"
                                                                     Stroke="#FFFFFFFF"
                                                                     StrokeThickness="1"
                                                                     VerticalAlignment="Top"
                                                                     Visibility="{Binding AfficheIndicateurEtat}"/>
                                                        </Grid>

                                                        <Grid Margin="0,12,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <ProgressBar Value="{Binding ProgressionPourcentage, Mode=OneWay}"
                                                                         Style="{StaticResource EssaiProgressBarStyle}"/>

                                                            <TextBlock Grid.Column="1"
                                                                       Margin="10,-4,0,0"
                                                                       Text="{Binding ProgressionTexte}"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource SummaryValueBrush}"
                                                                       VerticalAlignment="Center"/>
                                                        </Grid>

                                                        <Grid Margin="0,14,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <ComboBox Grid.Column="0"
                                                                      ItemsSource="{Binding StatutsDisponibles}"
                                                                      SelectedItem="{Binding Statut, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                      Style="{StaticResource EssaiStatusComboBoxStyle}"/>

                                                            <ComboBox Grid.Column="1"
                                                                      Margin="10,0,0,0"
                                                                      ItemsSource="{Binding ResultatsTraitementDisponibles}"
                                                                      SelectedItem="{Binding ResultatTraitement, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                                                <ComboBox.Style>
                                                                    <Style TargetType="ComboBox" BasedOn="{StaticResource EssaiResultatComboBoxStyle}">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding EstFait}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </ComboBox.Style>
                                                            </ComboBox>
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <Border Height="1"
                                        Margin="0,10,0,18"
                                        Background="{DynamicResource DataGridSurfaceBorderBrush}"
                                        Opacity="0.75"/>

                                <StackPanel>
                                    <TextBlock Text="Qualification"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTitleBrush}"/>

                                    <ItemsControl ItemsSource="{Binding DataContext.EssaisQualificationFiltres, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  Margin="0,14,0,0">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="4"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,12,12"
                                                        MinHeight="138"
                                                        Padding="14"
                                                        Background="{DynamicResource SearchCardBackgroundBrush}"
                                                        BorderBrush="{DynamicResource SearchCardBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="20">
                                                    <StackPanel>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock Text="{Binding NomEssai}"
                                                                       TextWrapping="Wrap"
                                                                       FontSize="15"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource PrimaryTitleBrush}"/>

                                                            <Ellipse Grid.Column="1"
                                                                     Width="12"
                                                                     Height="12"
                                                                     Margin="10,2,0,0"
                                                                     Fill="{Binding CouleurIndicateurEtat}"
                                                                     Stroke="#FFFFFFFF"
                                                                     StrokeThickness="1"
                                                                     VerticalAlignment="Top"
                                                                     Visibility="{Binding AfficheIndicateurEtat}"/>
                                                        </Grid>

                                                        <Grid Margin="0,12,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <ProgressBar Value="{Binding ProgressionPourcentage, Mode=OneWay}"
                                                                         Style="{StaticResource EssaiProgressBarStyle}"/>

                                                            <TextBlock Grid.Column="1"
                                                                       Margin="10,-4,0,0"
                                                                       Text="{Binding ProgressionTexte}"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource SummaryValueBrush}"
                                                                       VerticalAlignment="Center"/>
                                                        </Grid>

                                                        <Grid Margin="0,14,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <ComboBox Grid.Column="0"
                                                                      ItemsSource="{Binding StatutsDisponibles}"
                                                                      SelectedItem="{Binding Statut, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                      Style="{StaticResource EssaiStatusComboBoxStyle}"/>

                                                            <ComboBox Grid.Column="1"
                                                                      Margin="10,0,0,0"
                                                                      ItemsSource="{Binding ResultatsTraitementDisponibles}"
                                                                      SelectedItem="{Binding ResultatTraitement, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                                                <ComboBox.Style>
                                                                    <Style TargetType="ComboBox" BasedOn="{StaticResource EssaiResultatComboBoxStyle}">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding EstFait}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </ComboBox.Style>
                                                            </ComboBox>
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,18">
            <TextBlock Text="Vue d'ensemble des essais"
                       Foreground="{DynamicResource PrimaryTitleBrush}"
                       FontSize="24"
                       FontWeight="SemiBold"/>
            <TextBlock Text="Retrouve un produit à gauche, puis mets à jour les statuts de ses essais."
                       Margin="0,6,0,0"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       FontSize="14"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource SectionCardStyle}"
                    Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Produits"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTitleBrush}"/>

                    <TextBox Grid.Row="1"
                             Margin="0,14,0,16"
                             Style="{StaticResource RoundedTextBoxStyle}"
                             Text="{Binding SearchNomProduitEssais, UpdateSourceTrigger=PropertyChanged}"/>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding ProjetsEssaisView}"
                             SelectedItem="{Binding SelectedProjetEssais, Mode=TwoWay}"
                             Style="{StaticResource ProjetListBoxStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding NomProduit}"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTitleBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding NumeroProjet}"
                                               Margin="0,4,0,0"
                                               FontSize="13"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <TextBlock Text="{Binding Client}"
                                               Margin="0,3,0,0"
                                               FontSize="12"
                                               Foreground="{DynamicResource SummaryValueBrush}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <ContentControl Grid.Column="2"
                            Content="{Binding SelectedProjetEssais}">
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Setter Property="ContentTemplate" Value="{StaticResource SelectedProjetTemplate}"/>
                        <Style.Triggers>
                            <Trigger Property="Content" Value="{x:Null}">
                                <Setter Property="ContentTemplate" Value="{StaticResource EmptySelectionTemplate}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>
        </Grid>
    </Grid>
</UserControl>
