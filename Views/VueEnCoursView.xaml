<UserControl x:Class="MonTableurApp.Views.VueEnCoursView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="SummaryTileStyle" TargetType="Border">
            <Setter Property="Padding" Value="18,16"/>
            <Setter Property="Margin" Value="0,0,14,14"/>
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="Background" Value="#FFFFFFFF"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SummaryCardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinWidth" Value="200"/>
        </Style>

        <Style x:Key="ProjectCardStyle" TargetType="Border">
            <Setter Property="Width" Value="352"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,16,16"/>
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Background" Value="{DynamicResource SearchCardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SearchCardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="MiniMetricStyle" TargetType="Border">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Background" Value="{DynamicResource SummaryCardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SummaryCardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>

        <Style x:Key="DoneChipStyle" TargetType="Border">
            <Setter Property="Padding" Value="9,4"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Background" Value="#E7F6EC"/>
            <Setter Property="BorderBrush" Value="#B7DFC2"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="PendingChipStyle" TargetType="Border">
            <Setter Property="Padding" Value="9,4"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Background" Value="#FFF6DE"/>
            <Setter Property="BorderBrush" Value="#F2D48A"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="EnCoursProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="10"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="Foreground" Value="{DynamicResource InfoCardAccentBrush}"/>
            <Setter Property="Background" Value="{DynamicResource DataGridRowHoverBrush}"/>
        </Style>

        <DataTemplate x:Key="ProjetEnCoursCardTemplate">
            <Border Style="{StaticResource ProjectCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="{Binding NomProduit}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTitleBrush}"
                                       TextWrapping="Wrap"/>
                            <TextBlock Margin="0,6,0,0"
                                       Text="{Binding NumeroProjet, StringFormat=N° projet {0}}"
                                       FontSize="13"
                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBlock Margin="0,2,0,0"
                                       Text="{Binding Client}"
                                       FontSize="12"
                                       Foreground="{DynamicResource SummaryValueBrush}"/>
                        </StackPanel>

                        <Border Grid.Column="1"
                                Padding="10,5"
                                CornerRadius="13"
                                BorderThickness="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#EAF3FF"/>
                                    <Setter Property="BorderBrush" Value="#C3D8F6"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAttentionRequired}" Value="True">
                                            <Setter Property="Background" Value="#FFF1DD"/>
                                            <Setter Property="BorderBrush" Value="#F0C77A"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsNearlyDone}" Value="True">
                                            <Setter Property="Background" Value="#E7F6EC"/>
                                            <Setter Property="BorderBrush" Value="#B7DFC2"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding EtatPilotage}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTitleBrush}"/>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding Statut}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTitleBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding DateDebutLabel, StringFormat=Debut {0}}"
                                   FontSize="12"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <StackPanel Grid.Row="2" Margin="0,16,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding ProgressionLabel}"
                                       FontSize="12"
                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding ProgressionPourcentage, StringFormat={}{0}%}"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTitleBrush}"/>
                        </Grid>

                        <ProgressBar Margin="0,10,0,0"
                                     Value="{Binding ProgressionPourcentage, Mode=OneWay}"
                                     Style="{StaticResource EnCoursProgressBarStyle}"/>

                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding ResumeEtat}"
                                   FontSize="12"
                                   Foreground="{DynamicResource SummaryValueBrush}"/>
                    </StackPanel>

                    <Grid Grid.Row="3" Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource MiniMetricStyle}">
                            <StackPanel>
                                <TextBlock Text="Faits"
                                           FontSize="11"
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <TextBlock Margin="0,3,0,0"
                                           Text="{Binding EssaisFaits}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTitleBrush}"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource MiniMetricStyle}">
                            <StackPanel>
                                <TextBlock Text="En cours"
                                           FontSize="11"
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <TextBlock Margin="0,3,0,0"
                                           Text="{Binding EssaisEnCours}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTitleBrush}"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Margin="0" Style="{StaticResource MiniMetricStyle}">
                            <StackPanel>
                                <TextBlock Text="Restants"
                                           FontSize="11"
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <TextBlock Margin="0,3,0,0"
                                           Text="{Binding EssaisRestants}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTitleBrush}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="4"
                            Height="1"
                            Margin="0,18,0,16"
                            Background="{DynamicResource DataGridSurfaceBorderBrush}"
                            Opacity="0.7"/>

                    <StackPanel Grid.Row="5">
                        <StackPanel>
                            <TextBlock Text="Essais faits"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTitleBrush}"/>

                            <ItemsControl Margin="0,10,0,0"
                                          ItemsSource="{Binding EssaisFaitsPreview}">
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasEssaisFaits}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource DoneChipStyle}">
                                            <TextBlock Text="{Binding}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource PrimaryTitleBrush}"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource DoneChipStyle}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasEssaisFaitsOverflow}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding EssaisFaitsOverflowText}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTitleBrush}"/>
                            </Border>

                            <TextBlock Margin="0,10,0,0"
                                       Text="Aucun essai termine pour l'instant"
                                       FontSize="11"
                                       Foreground="{DynamicResource SecondaryTextBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasEssaisFaits}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Margin="0,16,0,0">
                            <TextBlock Text="A suivre"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTitleBrush}"/>

                            <ItemsControl Margin="0,10,0,0"
                                          ItemsSource="{Binding EssaisRestantsPreview}">
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasEssaisRestants}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource PendingChipStyle}">
                                            <TextBlock Text="{Binding}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource PrimaryTitleBrush}"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource PendingChipStyle}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasEssaisRestantsOverflow}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding EssaisRestantsOverflowText}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTitleBrush}"/>
                            </Border>

                            <TextBlock Margin="0,10,0,0"
                                       Text="Tous les essais concernes sont termines"
                                       FontSize="11"
                                       Foreground="{DynamicResource SecondaryTextBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasEssaisRestants}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="6">
        <Grid>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasProjetsEnCoursDashboard}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Padding="26"
                            CornerRadius="30"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource InfoCardBorderBrush}"
                            Margin="0,0,0,20">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FFF8F1" Offset="0"/>
                                <GradientStop Color="#FFFDFE" Offset="0.45"/>
                                <GradientStop Color="#FFF2F8" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>

                        <StackPanel>
                            <TextBlock Text="Pilotage des projets actifs"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTitleBrush}"/>
                            <TextBlock Margin="0,10,0,0"
                                       Text="Une vue de synthese pour presenter en quelques secondes l'etat d'avancement des produits, les essais deja boucles et les points qui demandent un suivi."
                                       FontSize="14"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBlock Margin="0,14,0,0"
                                       Text="{Binding AvancementGlobalEnCoursLabel}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource SummaryValueBrush}"/>
                        </StackPanel>
                    </Border>

                    <WrapPanel Margin="0,0,0,8">
                        <Border Style="{StaticResource SummaryTileStyle}">
                            <StackPanel>
                                <TextBlock Text="Projets actifs"
                                           FontSize="12"
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding ProjetsEnCoursDashboardCount}"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTitleBrush}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SummaryTileStyle}">
                            <StackPanel>
                                <TextBlock Text="Avancement global"
                                           FontSize="12"
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding AvancementGlobalEnCoursPourcentage, StringFormat={}{0}%}"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTitleBrush}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SummaryTileStyle}">
                            <StackPanel>
                                <TextBlock Text="Essais termines"
                                           FontSize="12"
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding EssaisTerminesDashboardTotal}"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTitleBrush}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SummaryTileStyle}">
                            <StackPanel>
                                <TextBlock Text="Points d'attention"
                                           FontSize="12"
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding ProjetsEnAttentionDashboardCount}"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTitleBrush}"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>

                    <Grid Margin="0,10,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Lecture projet par projet"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTitleBrush}"/>

                        <TextBlock Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Text="{Binding EssaisRestantsDashboardTotal, StringFormat={}{0} essais restants a traiter}"
                                   FontSize="12"
                                   Foreground="{DynamicResource SummaryValueBrush}"/>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding ProjetsEnCoursDashboard}"
                                  ItemTemplate="{StaticResource ProjetEnCoursCardTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Padding="34"
                CornerRadius="28"
                BorderThickness="1"
                BorderBrush="{DynamicResource InfoCardBorderBrush}"
                Background="{DynamicResource InfoCardBackgroundBrush}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MaxWidth="620">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasProjetsEnCoursDashboard}" Value="False">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <StackPanel>
                <TextBlock Text="Aucun projet actif"
                           FontSize="26"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           Foreground="{DynamicResource PrimaryTitleBrush}"/>
                <TextBlock Margin="0,12,0,0"
                           Text="La page se remplira automatiquement des qu'un projet aura un statut en cours."
                           FontSize="14"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource SecondaryTextBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
