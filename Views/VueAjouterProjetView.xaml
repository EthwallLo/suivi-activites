<UserControl x:Class="MonTableurApp.Views.VueAjouterProjetView"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DataGridSurfaceBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="24"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource SummaryLabelBrush}"/>
        </Style>

        <Style x:Key="RoundedTextBoxStyle" TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource SearchInputForegroundBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SearchInputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SearchInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FormComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource SearchInputForegroundBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SearchInputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SearchInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="14">
                                <Grid Margin="{TemplateBinding Padding}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <ContentPresenter Margin="0,0,10,0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="&#x25BE;"
                                               FontSize="15"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <ToggleButton Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          Opacity="0.01"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>

                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="White"
                                        BorderBrush="{DynamicResource SearchInputBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Margin="0,4,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="240">
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="{DynamicResource InfoCardAccentBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InfoCardAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,11"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryActionButtonStyle}">
            <Setter Property="Foreground" Value="{DynamicResource ThemeButtonForegroundBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ThemeButtonBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="EssaiSelectionCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,12,12"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Background" Value="{DynamicResource SearchCardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SearchCardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="KawaiiCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border x:Name="CheckBorder"
                                    Width="24"
                                    Height="24"
                                    Background="#FFFDFE"
                                    BorderBrush="{DynamicResource SearchInputBorderBrush}"
                                    BorderThickness="1.5"
                                    CornerRadius="12"
                                    VerticalAlignment="Top">
                                <TextBlock x:Name="CheckMark"
                                           Text="★"
                                           FontSize="11"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Opacity="0"/>
                            </Border>

                            <ContentPresenter Grid.Column="1"
                                              Margin="10,1,0,0"
                                              VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBorder" Property="Background" Value="{DynamicResource InfoCardAccentBrush}"/>
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{DynamicResource InfoCardAccentBrush}"/>
                                <Setter TargetName="CheckMark" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{DynamicResource MenuButtonHoverBorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="6,6,12,6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Style="{StaticResource SectionCardStyle}"
                    Padding="28">
                <StackPanel>
                    <TextBlock Text="Nouveau projet"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTitleBrush}"/>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1"
                  Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource SectionCardStyle}"
                        Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.ColumnSpan="3"
                                   Text="Informations projet"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTitleBrush}"/>

                        <StackPanel Grid.Row="1"
                                    Grid.Column="0"
                                    Margin="0,18,0,0">
                            <TextBlock Text="Numéro projet"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="NumeroProjetTextBox"
                                     Style="{StaticResource RoundedTextBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1"
                                    Grid.Column="2"
                                    Margin="0,18,0,0">
                            <TextBlock Text="Nom produit"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="NomProduitTextBox"
                                     Style="{StaticResource RoundedTextBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2"
                                    Grid.Column="0"
                                    Margin="0,18,0,0">
                            <TextBlock Text="Famille de produits"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox x:Name="FamilleProduitComboBox"
                                      ItemsSource="{Binding FamillesProduit}"
                                      Style="{StaticResource FormComboBoxStyle}"
                                      SelectionChanged="FamilleProduit_SelectionChanged"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2"
                                    Grid.Column="2"
                                    Margin="0,18,0,0">
                            <TextBlock Text="Client"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox x:Name="ClientComboBox"
                                      ItemsSource="{Binding Clients}"
                                      Style="{StaticResource FormComboBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3"
                                    Grid.Column="0"
                                    Margin="0,18,0,0">
                            <TextBlock Text="Demandeur"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox x:Name="DemandeurComboBox"
                                      ItemsSource="{Binding Demandeurs}"
                                      Style="{StaticResource FormComboBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3"
                                    Grid.Column="2"
                                    Margin="0,18,0,0">
                            <TextBlock Text="Type d'activité"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox x:Name="TypeActiviteComboBox"
                                      ItemsSource="{Binding TypesActivite}"
                                      Style="{StaticResource FormComboBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="4"
                                    Grid.Column="0"
                                    Margin="0,18,0,0">
                            <TextBlock Text="Statut"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox x:Name="StatutComboBox"
                                      ItemsSource="{Binding Statuts}"
                                      Style="{StaticResource FormComboBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="5"
                                    Grid.ColumnSpan="3"
                                    Margin="0,18,0,0">
                            <TextBlock Text="Dossier racine"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="DossierRacineTextBox"
                                     Style="{StaticResource RoundedTextBoxStyle}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource SectionCardStyle}"
                        Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.ColumnSpan="3"
                                   Text="Dates et notes"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTitleBrush}"/>

                        <StackPanel Grid.Row="1"
                                    Grid.Column="0"
                                    Margin="0,18,0,0">
                            <TextBlock Text="Date de début"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="DateDebutTextBox"
                                     Style="{StaticResource RoundedTextBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1"
                                    Grid.Column="2"
                                    Margin="0,18,0,0">
                            <TextBlock Text="Date prévisionnelle"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="DatePrevisionnelleTextBox"
                                     Style="{StaticResource RoundedTextBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2"
                                    Grid.Column="0"
                                    Margin="0,18,0,0">
                            <TextBlock Text="Date de fin"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="DateFinTextBox"
                                     Style="{StaticResource RoundedTextBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3"
                                    Grid.ColumnSpan="3"
                                    Margin="0,18,0,0">
                            <TextBlock Text="Commentaires"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="CommentairesTextBox"
                                     Style="{StaticResource RoundedTextBoxStyle}"
                                     Height="150"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2"
                    Margin="0,18,0,0"
                    Style="{StaticResource SectionCardStyle}"
                    Padding="24">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Essais à prévoir"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTitleBrush}"/>
                        </StackPanel>

                        <Button x:Name="ToggleEssaisSelectionButton"
                                Grid.Column="1"
                                Margin="12,0,0,0"
                                VerticalAlignment="Top"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Click="ToggleEssaisSelection_Click"/>
                    </Grid>

                    <TextBlock Text="Pré-qualification"
                               Margin="0,20,0,10"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTitleBrush}"/>

                    <ItemsControl ItemsSource="{Binding EssaisPreQualificationSelection, ElementName=Root}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource EssaiSelectionCardStyle}">
                                    <CheckBox Content="{Binding NomEssai}"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Style="{StaticResource KawaiiCheckBoxStyle}"
                                              FontSize="14"
                                              FontWeight="SemiBold"
                                              Foreground="{DynamicResource PrimaryTitleBrush}"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Qualification"
                               Margin="0,12,0,10"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTitleBrush}"/>

                    <ItemsControl ItemsSource="{Binding EssaisQualificationSelection, ElementName=Root}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource EssaiSelectionCardStyle}">
                                    <CheckBox Content="{Binding NomEssai}"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Style="{StaticResource KawaiiCheckBoxStyle}"
                                              FontSize="14"
                                              FontWeight="SemiBold"
                                              Foreground="{DynamicResource PrimaryTitleBrush}"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Essais extérieurs"
                               Margin="0,12,0,10"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTitleBrush}"/>

                    <ItemsControl ItemsSource="{Binding EssaisExterieursSelection, ElementName=Root}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource EssaiSelectionCardStyle}">
                                    <CheckBox Content="{Binding NomEssai}"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Style="{StaticResource KawaiiCheckBoxStyle}"
                                              FontSize="14"
                                              FontWeight="SemiBold"
                                              Foreground="{DynamicResource PrimaryTitleBrush}"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Grid.Row="3"
                    Margin="0,18,0,0"
                    Style="{StaticResource SectionCardStyle}"
                    Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>


                    <Button Grid.Column="1"
                            Margin="12,0,0,0"
                            Content="Vider"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            Click="ViderFormulaire_Click"/>

                    <Button Grid.Column="2"
                            Margin="12,0,0,0"
                            Content="Ajouter le projet"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Click="AjouterProjet_Click"/>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
