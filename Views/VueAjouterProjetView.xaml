<UserControl x:Class="MonTableurApp.Views.VueAjouterProjetView"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework">

    <UserControl.Resources>
        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DataGridSurfaceBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="24"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource SummaryLabelBrush}"/>
        </Style>

        <Style x:Key="RoundedTextBoxStyle" TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource SearchInputForegroundBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SearchInputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SearchInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FormComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource SearchInputForegroundBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SearchInputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SearchInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="14">
                                <Grid Margin="{TemplateBinding Padding}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <ContentPresenter Margin="0,0,10,0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="&#x25BE;"
                                               FontSize="15"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <ToggleButton Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          Opacity="0.01"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>

                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="White"
                                        BorderBrush="{DynamicResource SearchInputBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Margin="0,4,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="240">
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InvisibleRepeatButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Rectangle Fill="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CuteThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                Background="{DynamicResource ScrollThumbBrush}"
                                CornerRadius="8"
                                Margin="1"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource ScrollThumbHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Border x:Name="TrackBorder"
                                    Background="{DynamicResource ScrollTrackBrush}"
                                    CornerRadius="8"/>
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton x:Name="DecreaseButton"
                                                  Style="{StaticResource InvisibleRepeatButtonStyle}"
                                                  Command="ScrollBar.PageLeftCommand"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource CuteThumbStyle}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton x:Name="IncreaseButton"
                                                  Style="{StaticResource InvisibleRepeatButtonStyle}"
                                                  Command="ScrollBar.PageRightCommand"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="TrackBorder" Property="Height" Value="12"/>
                                <Setter TargetName="TrackBorder" Property="Margin" Value="0,10,0,2"/>
                                <Setter Property="Height" Value="24"/>
                            </Trigger>
                            <Trigger Property="Orientation" Value="Vertical">
                                <Setter TargetName="TrackBorder" Property="Width" Value="12"/>
                                <Setter TargetName="TrackBorder" Property="Margin" Value="2,0,0,0"/>
                                <Setter Property="Width" Value="16"/>
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="True"/>
                                <Setter TargetName="DecreaseButton" Property="Command" Value="ScrollBar.PageUpCommand"/>
                                <Setter TargetName="IncreaseButton" Property="Command" Value="ScrollBar.PageDownCommand"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GridCalendarPopupToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ButtonChrome"
                                Width="22"
                                Height="22"
                                Background="{DynamicResource DataGridAltRowBrush}"
                                BorderBrush="{DynamicResource SearchInputBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="11"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="CalendarIcon"
                                       Text="&#xE787;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="12"
                                       Foreground="{TemplateBinding Foreground}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource DataGridRowHoverBrush}"/>
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{DynamicResource SummaryCardBorderBrush}"/>
                                <Setter TargetName="CalendarIcon" Property="Foreground" Value="{DynamicResource PrimaryTitleBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource DataGridRowSelectedBrush}"/>
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{DynamicResource PrimaryTitleBrush}"/>
                                <Setter TargetName="CalendarIcon" Property="Foreground" Value="{DynamicResource PrimaryTitleBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource DataGridRowSelectedBrush}"/>
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{DynamicResource PrimaryTitleBrush}"/>
                                <Setter TargetName="CalendarIcon" Property="Foreground" Value="{DynamicResource DataGridHeaderForegroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GridCalendarNavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="NavButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavButtonBorder" Property="Background" Value="{DynamicResource DataGridRowHoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTitleBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="NavButtonBorder" Property="Background" Value="{DynamicResource DataGridRowSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GridCalendarHeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource DataGridAltRowBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SearchInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTitleBrush}"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="HeaderButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderButtonBorder" Property="Background" Value="{DynamicResource DataGridRowHoverBrush}"/>
                                <Setter TargetName="HeaderButtonBorder" Property="BorderBrush" Value="{DynamicResource SummaryCardBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="HeaderButtonBorder" Property="Background" Value="{DynamicResource DataGridRowSelectedBrush}"/>
                                <Setter TargetName="HeaderButtonBorder" Property="BorderBrush" Value="{DynamicResource PrimaryTitleBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GridCalendarButtonStyle" TargetType="CalendarButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource SearchInputForegroundBrush}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="MinWidth" Value="42"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CalendarButton">
                        <Border x:Name="MonthBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Margin="{TemplateBinding Margin}"
                                MinWidth="{TemplateBinding MinWidth}"
                                MinHeight="{TemplateBinding MinHeight}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MonthBorder" Property="Background" Value="{DynamicResource DataGridRowHoverBrush}"/>
                                <Setter TargetName="MonthBorder" Property="BorderBrush" Value="{DynamicResource SummaryCardBorderBrush}"/>
                                <Setter TargetName="MonthBorder" Property="BorderThickness" Value="1"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTitleBrush}"/>
                            </Trigger>
                            <Trigger Property="HasSelectedDays" Value="True">
                                <Setter TargetName="MonthBorder" Property="Background" Value="{DynamicResource DataGridRowSelectedBrush}"/>
                                <Setter TargetName="MonthBorder" Property="BorderBrush" Value="{DynamicResource PrimaryTitleBrush}"/>
                                <Setter TargetName="MonthBorder" Property="BorderThickness" Value="1"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTitleBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.32"/>
                            </Trigger>
                            <Trigger Property="IsInactive" Value="True">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GridCalendarDayButtonStyle" TargetType="primitives:CalendarDayButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource SearchInputForegroundBrush}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="primitives:CalendarDayButton">
                        <Border x:Name="DayBorder"
                                MinWidth="30"
                                MinHeight="28"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DayBorder" Property="Background" Value="{DynamicResource DataGridRowHoverBrush}"/>
                                <Setter TargetName="DayBorder" Property="BorderBrush" Value="{DynamicResource SummaryCardBorderBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTitleBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="DayBorder" Property="Background" Value="{DynamicResource DataGridRowSelectedBrush}"/>
                                <Setter TargetName="DayBorder" Property="BorderBrush" Value="{DynamicResource PrimaryTitleBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTitleBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.28"/>
                            </Trigger>
                            <Trigger Property="IsToday" Value="True">
                                <Setter TargetName="DayBorder" Property="BorderBrush" Value="{DynamicResource SummaryCardBorderBrush}"/>
                                <Setter TargetName="DayBorder" Property="Background" Value="{DynamicResource DataGridAltRowBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsInactive" Value="True">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                            <Trigger Property="IsBlackedOut" Value="True">
                                <Setter Property="IsHitTestVisible" Value="False"/>
                                <Setter Property="Focusable" Value="False"/>
                                <Setter Property="Opacity" Value="0.3"/>
                                <Setter TargetName="DayBorder" Property="Background" Value="Transparent"/>
                                <Setter TargetName="DayBorder" Property="BorderBrush" Value="Transparent"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GridCalendarItemStyle" TargetType="primitives:CalendarItem">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="{DynamicResource SearchInputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="primitives:CalendarItem">
                        <ControlTemplate.Resources>
                            <DataTemplate x:Key="DayTitleTemplate">
                                <TextBlock Text="{Binding}"
                                           Margin="0,0,0,6"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </DataTemplate>
                        </ControlTemplate.Resources>

                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18"
                                Padding="6">
                            <Grid x:Name="PART_Root">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0"
                                      Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Button x:Name="PART_PreviousButton"
                                            Grid.Column="0"
                                            Width="30"
                                            Height="30"
                                            Margin="0,0,8,0"
                                            Style="{StaticResource GridCalendarNavButtonStyle}"
                                            Content="&#xE76B;"
                                            FontFamily="Segoe MDL2 Assets"
                                            FontSize="12"/>

                                    <Button x:Name="PART_HeaderButton"
                                            Grid.Column="1"
                                            HorizontalAlignment="Stretch"
                                            Style="{StaticResource GridCalendarHeaderButtonStyle}"/>

                                    <Button x:Name="PART_NextButton"
                                            Grid.Column="2"
                                            Width="30"
                                            Height="30"
                                            Margin="8,0,0,0"
                                            Style="{StaticResource GridCalendarNavButtonStyle}"
                                            Content="&#xE76C;"
                                            FontFamily="Segoe MDL2 Assets"
                                            FontSize="12"/>
                                </Grid>

                                <Grid x:Name="PART_MonthView"
                                      Grid.Row="1"
                                      Margin="2,0,2,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                </Grid>

                                <Grid x:Name="PART_YearView"
                                      Grid.Row="1"
                                      Margin="6,4,6,6"
                                      Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                </Grid>

                                <Border x:Name="PART_DisabledVisual"
                                        Grid.RowSpan="2"
                                        Background="#80FFFFFF"
                                        CornerRadius="18"
                                        Visibility="Collapsed"/>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="PART_DisabledVisual" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding DisplayMode, RelativeSource={RelativeSource AncestorType=Calendar}}"
                                         Value="{x:Static CalendarMode.Month}">
                                <Setter TargetName="PART_MonthView" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="PART_YearView" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding DisplayMode, RelativeSource={RelativeSource AncestorType=Calendar}}"
                                         Value="{x:Static CalendarMode.Year}">
                                <Setter TargetName="PART_MonthView" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="PART_YearView" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding DisplayMode, RelativeSource={RelativeSource AncestorType=Calendar}}"
                                         Value="{x:Static CalendarMode.Decade}">
                                <Setter TargetName="PART_MonthView" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="PART_YearView" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GridCalendarStyle" TargetType="Calendar">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Language" Value="fr-FR"/>
            <Setter Property="FirstDayOfWeek" Value="Monday"/>
            <Setter Property="Background" Value="{DynamicResource SearchInputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource SearchInputForegroundBrush}"/>
            <Setter Property="CalendarButtonStyle" Value="{StaticResource GridCalendarButtonStyle}"/>
            <Setter Property="CalendarDayButtonStyle" Value="{StaticResource GridCalendarDayButtonStyle}"/>
            <Setter Property="CalendarItemStyle" Value="{StaticResource GridCalendarItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Calendar">
                        <StackPanel x:Name="PART_Root"
                                    Background="{TemplateBinding Background}">
                            <primitives:CalendarItem x:Name="PART_CalendarItem"
                                                     Background="{TemplateBinding Background}"
                                                     BorderBrush="{TemplateBinding BorderBrush}"
                                                     BorderThickness="{TemplateBinding BorderThickness}"
                                                     Style="{TemplateBinding CalendarItemStyle}"/>
                        </StackPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GridCalendarPopupStyle" TargetType="Popup">
            <Setter Property="AllowsTransparency" Value="True"/>
            <Setter Property="PopupAnimation" Value="Fade"/>
            <Setter Property="StaysOpen" Value="False"/>
        </Style>

        <Style x:Key="GridDateDisplayTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SearchInputForegroundBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DateFieldSurfaceStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SearchInputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SearchInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="12,9"/>
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="{DynamicResource InfoCardAccentBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InfoCardAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,11"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryActionButtonStyle}">
            <Setter Property="Foreground" Value="{DynamicResource ThemeButtonForegroundBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ThemeButtonBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="EssaiSelectionCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,12,12"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Background" Value="{DynamicResource SearchCardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SearchCardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="KawaiiCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border x:Name="CheckBorder"
                                    Width="24"
                                    Height="24"
                                    Background="#FFFDFE"
                                    BorderBrush="{DynamicResource SearchInputBorderBrush}"
                                    BorderThickness="1.5"
                                    CornerRadius="12"
                                    VerticalAlignment="Top">
                                <TextBlock x:Name="CheckMark"
                                           Text="★"
                                           FontSize="11"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Opacity="0"/>
                            </Border>

                            <ContentPresenter Grid.Column="1"
                                              Margin="10,1,0,0"
                                              VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBorder" Property="Background" Value="{DynamicResource InfoCardAccentBrush}"/>
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{DynamicResource InfoCardAccentBrush}"/>
                                <Setter TargetName="CheckMark" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{DynamicResource MenuButtonHoverBorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="6,6,12,6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource SectionCardStyle}"
                        Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.ColumnSpan="3"
                                   Text="Informations projet"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTitleBrush}"/>

                        <StackPanel Grid.Row="1"
                                    Grid.Column="0"
                                    Margin="0,18,0,0">
                            <TextBlock Text="Numéro projet"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="NumeroProjetTextBox"
                                     Style="{StaticResource RoundedTextBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1"
                                    Grid.Column="2"
                                    Margin="0,18,0,0">
                            <TextBlock Text="Nom produit"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="NomProduitTextBox"
                                     Style="{StaticResource RoundedTextBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2"
                                    Grid.Column="0"
                                    Margin="0,18,0,0">
                            <TextBlock Text="Famille de produits"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox x:Name="FamilleProduitComboBox"
                                      ItemsSource="{Binding FamillesProduit}"
                                      Style="{StaticResource FormComboBoxStyle}"
                                      SelectionChanged="FamilleProduit_SelectionChanged"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2"
                                    Grid.Column="2"
                                    Margin="0,18,0,0">
                            <TextBlock Text="Client"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox x:Name="ClientComboBox"
                                      ItemsSource="{Binding Clients}"
                                      Style="{StaticResource FormComboBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3"
                                    Grid.Column="0"
                                    Margin="0,18,0,0">
                            <TextBlock Text="Demandeur"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox x:Name="DemandeurComboBox"
                                      ItemsSource="{Binding Demandeurs}"
                                      Style="{StaticResource FormComboBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3"
                                    Grid.Column="2"
                                    Margin="0,18,0,0">
                            <TextBlock Text="Type d'activité"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox x:Name="TypeActiviteComboBox"
                                      ItemsSource="{Binding TypesActivite}"
                                      Style="{StaticResource FormComboBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="4"
                                    Grid.Column="0"
                                    Margin="0,18,0,0">
                            <TextBlock Text="Statut"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox x:Name="StatutComboBox"
                                      ItemsSource="{Binding Statuts}"
                                      Style="{StaticResource FormComboBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="5"
                                    Grid.ColumnSpan="3"
                                    Margin="0,18,0,0">
                            <TextBlock Text="Dossier racine"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="DossierRacineTextBox"
                                         Style="{StaticResource RoundedTextBoxStyle}"/>

                                <Button Grid.Column="1"
                                        Margin="12,0,0,0"
                                        Content="Parcourir"
                                        Style="{StaticResource SecondaryActionButtonStyle}"
                                        Click="ParcourirDossierRacine_Click"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource SectionCardStyle}"
                        Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.ColumnSpan="3"
                                   Text="Dates et notes"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTitleBrush}"/>

                        <StackPanel Grid.Row="1"
                                    Grid.Column="0"
                                    Margin="0,18,0,0">
                            <TextBlock Text="Date de début"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <Border Style="{StaticResource DateFieldSurfaceStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Margin="0,0,8,0"
                                               Style="{StaticResource GridDateDisplayTextStyle}"
                                               Text="{Binding SelectedDate, ElementName=DateDebutCalendar, StringFormat={}{0:dd/MM/yyyy}}"/>

                                    <ToggleButton x:Name="DateDebutToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource GridCalendarPopupToggleStyle}"/>

                                    <Popup Placement="Bottom"
                                           PlacementTarget="{Binding ElementName=DateDebutToggle}"
                                           IsOpen="{Binding IsChecked, ElementName=DateDebutToggle, Mode=TwoWay}"
                                           Style="{StaticResource GridCalendarPopupStyle}">
                                        <Border Padding="10"
                                                Background="{DynamicResource SearchInputBackgroundBrush}"
                                                BorderBrush="{DynamicResource SearchInputBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="22">
                                            <Calendar x:Name="DateDebutCalendar"
                                                      Style="{StaticResource GridCalendarStyle}"/>
                                        </Border>
                                    </Popup>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="1"
                                    Grid.Column="2"
                                    Margin="0,18,0,0">
                            <TextBlock Text="Date prévisionnelle"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <Border Style="{StaticResource DateFieldSurfaceStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Margin="0,0,8,0"
                                               Style="{StaticResource GridDateDisplayTextStyle}"
                                               Text="{Binding SelectedDate, ElementName=DatePrevisionnelleCalendar, StringFormat={}{0:dd/MM/yyyy}}"/>

                                    <ToggleButton x:Name="DatePrevisionnelleToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource GridCalendarPopupToggleStyle}"/>

                                    <Popup Placement="Bottom"
                                           PlacementTarget="{Binding ElementName=DatePrevisionnelleToggle}"
                                           IsOpen="{Binding IsChecked, ElementName=DatePrevisionnelleToggle, Mode=TwoWay}"
                                           Style="{StaticResource GridCalendarPopupStyle}">
                                        <Border Padding="10"
                                                Background="{DynamicResource SearchInputBackgroundBrush}"
                                                BorderBrush="{DynamicResource SearchInputBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="22">
                                            <Calendar x:Name="DatePrevisionnelleCalendar"
                                                      Style="{StaticResource GridCalendarStyle}"
                                                      DisplayDateStart="{Binding SelectedDate, ElementName=DateDebutCalendar}"/>
                                        </Border>
                                    </Popup>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="2"
                                    Grid.Column="0"
                                    Margin="0,18,0,0">
                            <TextBlock Text="Date de fin"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <Border Style="{StaticResource DateFieldSurfaceStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Margin="0,0,8,0"
                                               Style="{StaticResource GridDateDisplayTextStyle}"
                                               Text="{Binding SelectedDate, ElementName=DateFinCalendar, StringFormat={}{0:dd/MM/yyyy}}"/>

                                    <ToggleButton x:Name="DateFinToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource GridCalendarPopupToggleStyle}"/>

                                    <Popup Placement="Bottom"
                                           PlacementTarget="{Binding ElementName=DateFinToggle}"
                                           IsOpen="{Binding IsChecked, ElementName=DateFinToggle, Mode=TwoWay}"
                                           Style="{StaticResource GridCalendarPopupStyle}">
                                        <Border Padding="10"
                                                Background="{DynamicResource SearchInputBackgroundBrush}"
                                                BorderBrush="{DynamicResource SearchInputBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="22">
                                            <Calendar x:Name="DateFinCalendar"
                                                      Style="{StaticResource GridCalendarStyle}"
                                                      DisplayDateStart="{Binding SelectedDate, ElementName=DateDebutCalendar}"/>
                                        </Border>
                                    </Popup>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="3"
                                    Grid.ColumnSpan="3"
                                    Margin="0,18,0,0">
                            <TextBlock Text="Commentaires"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="CommentairesTextBox"
                                     Style="{StaticResource RoundedTextBoxStyle}"
                                     Height="150"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,18,0,0"
                    Style="{StaticResource SectionCardStyle}"
                    Padding="24">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Essais à prévoir"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTitleBrush}"/>
                        </StackPanel>

                        <Button x:Name="ToggleEssaisSelectionButton"
                                Grid.Column="1"
                                Margin="12,0,0,0"
                                VerticalAlignment="Top"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Click="ToggleEssaisSelection_Click"/>
                    </Grid>

                    <TextBlock Text="Pré-qualification"
                               Margin="0,20,0,10"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTitleBrush}"/>

                    <ItemsControl ItemsSource="{Binding EssaisPreQualificationSelection, ElementName=Root}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource EssaiSelectionCardStyle}">
                                    <CheckBox Content="{Binding NomEssai}"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Style="{StaticResource KawaiiCheckBoxStyle}"
                                              FontSize="14"
                                              FontWeight="SemiBold"
                                              Foreground="{DynamicResource PrimaryTitleBrush}"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Qualification"
                               Margin="0,12,0,10"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTitleBrush}"/>

                    <ItemsControl ItemsSource="{Binding EssaisQualificationSelection, ElementName=Root}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource EssaiSelectionCardStyle}">
                                    <CheckBox Content="{Binding NomEssai}"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Style="{StaticResource KawaiiCheckBoxStyle}"
                                              FontSize="14"
                                              FontWeight="SemiBold"
                                              Foreground="{DynamicResource PrimaryTitleBrush}"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Essais extérieurs"
                               Margin="0,12,0,10"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTitleBrush}"/>

                    <ItemsControl ItemsSource="{Binding EssaisExterieursSelection, ElementName=Root}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource EssaiSelectionCardStyle}">
                                    <CheckBox Content="{Binding NomEssai}"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Style="{StaticResource KawaiiCheckBoxStyle}"
                                              FontSize="14"
                                              FontWeight="SemiBold"
                                              Foreground="{DynamicResource PrimaryTitleBrush}"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Margin="0,18,0,0"
                    Style="{StaticResource SectionCardStyle}"
                    Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>


                    <Button Grid.Column="1"
                            Margin="12,0,0,0"
                            Content="Vider"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            Click="ViderFormulaire_Click"/>

                    <Button Grid.Column="2"
                            Margin="12,0,0,0"
                            Content="Ajouter le projet"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Click="AjouterProjet_Click"/>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
