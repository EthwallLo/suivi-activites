<UserControl x:Class="MonTableurApp.Views.VueAgendaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="Transparent">
        <Border MaxWidth="620"
                Padding="34"
                Background="{DynamicResource InfoCardBackgroundBrush}"
                BorderBrush="{DynamicResource InfoCardBorderBrush}"
                BorderThickness="1"
                CornerRadius="28"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Agenda"
                           Foreground="{DynamicResource PrimaryTitleBrush}"
                           FontSize="28"
                           FontWeight="SemiBold"
                           TextAlignment="Center"/>
                <TextBlock Text="Cette page vide servira plus tard pour le planning, les échéances et les rappels."
                           Margin="0,14,0,0"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="16"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
