<Window x:Class="MonTableurApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Suivi des activites"
        Width="1440"
        Height="900"
        MinWidth="1200"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        Background="#F4F1EA">

    <Window.Resources>
        <LinearGradientBrush x:Key="SidebarBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#1C3A35" Offset="0"/>
            <GradientStop Color="#2A5750" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#F8F5EF"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="16">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#3C6A62"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#17332F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="{StaticResource SidebarBrush}">
            <Grid Margin="28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <Border Width="58"
                            Height="58"
                            Background="#F0B36D"
                            CornerRadius="18"
                            HorizontalAlignment="Left">
                        <TextBlock Text="SA"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#1F2D2A"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Suivi des activites"
                               Margin="0,22,0,0"
                               Foreground="#F8F5EF"
                               FontSize="28"
                               FontWeight="SemiBold"/>

                    <TextBlock Text="Une vue simple et agreable pour piloter les projets et les essais."
                               Margin="0,10,0,0"
                               Foreground="#D8E5E1"
                               FontSize="14"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Margin="0,36,0,0">
                    <Button Content="Vue generale"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="VueGenerale_Click"/>
                </StackPanel>

                <Border Grid.Row="2"
                        Padding="18"
                        Background="#214640"
                        CornerRadius="20">
                    <StackPanel>
                        <TextBlock Text="Objectif"
                                   Foreground="#F0B36D"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Suivre chaque projet en un coup d'oeil, meme avec un acces limite au travail."
                                   Margin="0,8,0,0"
                                   Foreground="#F8F5EF"
                                   FontSize="15"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1"
              Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Margin="8,4,8,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Vue generale des projets"
                               FontSize="32"
                               FontWeight="SemiBold"
                               Foreground="#22312E"/>
                    <TextBlock Text="Les infos importantes restent visibles, dans un espace plus confortable et plus lisible."
                               Margin="0,8,0,0"
                               Foreground="#5D6E69"
                               FontSize="15"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Padding="18,12"
                        Background="#E7DED2"
                        CornerRadius="18"
                        VerticalAlignment="Center">
                    <TextBlock Text="Suivi simple des essais"
                               Foreground="#3D4B48"
                               FontWeight="SemiBold"/>
                </Border>
            </Grid>

            <Border Grid.Row="1"
                    Background="#FCFBF8"
                    CornerRadius="28"
                    Padding="18"
                    BorderBrush="#E5DDD2"
                    BorderThickness="1">
                <ContentControl x:Name="MainContent"/>
            </Border>
        </Grid>
    </Grid>
</Window>
