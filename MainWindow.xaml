<Window x:Class="MonTableurApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Suivi des activites"
        Icon="logg.png"
        Width="1480"
        Height="920"
        MinWidth="1260"
        MinHeight="780"
        WindowStartupLocation="CenterScreen"
        Background="#FFF6FB">

    <Window.Resources>
        <LinearGradientBrush x:Key="WindowBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFF7FC" Offset="0"/>
            <GradientStop Color="#FFF0F7" Offset="0.55"/>
            <GradientStop Color="#FFF8EF" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="SidebarBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FFD7E8" Offset="0"/>
            <GradientStop Color="#F6D8FF" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#7B4D73"/>
            <Setter Property="Background" Value="#FFFDFE"/>
            <Setter Property="BorderBrush" Value="#F6BAD8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FFF0F8"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#EFA6CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FFE7F4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WindowBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="315"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Margin="18"
                Background="{StaticResource SidebarBrush}"
                CornerRadius="30"
                BorderBrush="#F5B7D7"
                BorderThickness="1">
            <Grid Margin="28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <Border Width="66"
                            Height="66"
                            Background="#FFF9FD"
                            CornerRadius="22"
                            BorderBrush="#F4B5D6"
                            BorderThickness="1"
                            HorizontalAlignment="Left">
                        <Image Source="logg.png"
                               Width="48"
                               Height="48"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Suivi des activités"
                               Margin="0,22,0,0"
                               Foreground="#8B4B7C"
                               FontSize="29"
                               FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Margin="0,38,0,0">
                    <Button Content="Vue generale"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="VueGenerale_Click"/>
                </StackPanel>

                <Border Grid.Row="2"
                        Padding="18"
                        Background="#FFF6FB"
                        CornerRadius="22"
                        BorderBrush="#F5BCD9"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Mode maquette"
                                   Foreground="#E28AB9"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Les projets affichés sont des données mockées pour construire la vue générale."
                                   Margin="0,8,0,0"
                                   Foreground="#8E617E"
                                   FontSize="15"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1"
              Margin="24,22,24,22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Margin="8,4,8,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Vue générale des projets"
                               FontSize="33"
                               FontWeight="SemiBold"
                               Foreground="#8B4B7C"/>
                    <TextBlock Text="Les infos essentielles, en un coup d'œil."
                               Margin="0,8,0,0"
                               Foreground="#9B758A"
                               FontSize="15"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Padding="18,12"
                        Background="#FFF4D9"
                        BorderBrush="#F5D59A"
                        BorderThickness="1"
                        CornerRadius="18"
                        VerticalAlignment="Center">
                    <TextBlock Text="Vers. 0.1"
                               Foreground="#B78641"
                               FontWeight="SemiBold"/>
                </Border>
            </Grid>

            <Border Grid.Row="1"
                    Background="#FFFCFE"
                    CornerRadius="30"
                    Padding="18"
                    BorderBrush="#F4D4E5"
                    BorderThickness="1">
                <ContentControl x:Name="MainContent"/>
            </Border>
        </Grid>
    </Grid>
</Window>
