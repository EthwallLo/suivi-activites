<Window x:Class="MonTableurApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Suivi des activites"
        Icon="logg.png"
        Width="1480"
        Height="920"
        MinWidth="1260"
        MinHeight="780"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource MenuButtonForegroundBrush}"/>
            <Setter Property="Background" Value="{DynamicResource MenuButtonBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource MenuButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource MenuButtonHoverBackgroundBrush}"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource MenuButtonHoverBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource MenuButtonPressedBackgroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThemeSwitchButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource ThemeButtonForegroundBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ThemeButtonBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ThemeBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThemeBorder" Property="Background" Value="{DynamicResource MenuButtonHoverBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ThemeBorder" Property="Background" Value="{DynamicResource MenuButtonPressedBackgroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="315"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Margin="18"
                Background="{DynamicResource SidebarBrush}"
                CornerRadius="30"
                BorderBrush="{DynamicResource SidebarBorderBrush}"
                BorderThickness="1">
            <Grid Margin="28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <Border Width="66"
                            Height="66"
                            Background="{DynamicResource LogoChipBackgroundBrush}"
                            CornerRadius="22"
                            BorderBrush="{DynamicResource LogoChipBorderBrush}"
                            BorderThickness="1"
                            HorizontalAlignment="Left">
                        <Image Source="logg.png"
                               Width="48"
                               Height="48"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Suivi des activites"
                               Margin="0,22,0,0"
                               Foreground="{DynamicResource PrimaryTitleBrush}"
                               FontSize="29"
                               FontWeight="SemiBold"/>

                    <TextBlock Text="Un mini cockpit pastel pour suivre les projets et les essais."
                               Margin="0,10,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="14"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Margin="0,38,0,0">
                    <Button Content="Vue generale"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="VueGenerale_Click"/>
                </StackPanel>

                <Border Grid.Row="2"
                        Padding="18"
                        Background="{DynamicResource InfoCardBackgroundBrush}"
                        CornerRadius="22"
                        BorderBrush="{DynamicResource InfoCardBorderBrush}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Mode maquette"
                                   Foreground="{DynamicResource InfoCardAccentBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Les projets affiches sont des donnees mockees pour construire la vue generale."
                                   Margin="0,8,0,0"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontSize="15"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1"
              Margin="24,22,24,22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Margin="8,4,8,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Vue generale des projets"
                               FontSize="33"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTitleBrush}"/>
                    <TextBlock Text="Les infos essentielles, en un coup d'oeil."
                               Margin="0,8,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="15"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Padding="18,12"
                            Background="{DynamicResource VersionBadgeBackgroundBrush}"
                            BorderBrush="{DynamicResource VersionBadgeBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="18"
                            VerticalAlignment="Center">
                        <TextBlock Text="Vers. 0.1"
                                   Foreground="{DynamicResource VersionBadgeForegroundBrush}"
                                   FontWeight="SemiBold"/>
                    </Border>

                    <Button x:Name="ThemeToggleButton"
                            Content="Blue pastel kawaii"
                            Style="{StaticResource ThemeSwitchButtonStyle}"
                            Click="ThemeToggle_Click"/>
                </StackPanel>
            </Grid>

            <Border Grid.Row="1"
                    Background="{DynamicResource ContentBackgroundBrush}"
                    CornerRadius="30"
                    Padding="18"
                    BorderBrush="{DynamicResource ContentBorderBrush}"
                    BorderThickness="1">
                <ContentControl x:Name="MainContent"/>
            </Border>
        </Grid>
    </Grid>
</Window>
