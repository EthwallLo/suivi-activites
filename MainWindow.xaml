<Window x:Class="MonTableurApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Suivi des activités"
        Icon="logg.png"
        Width="1600"
        Height="920"
        MinWidth="1360"
        MinHeight="780"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource MenuButtonForegroundBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,12,10,14"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="ButtonRoot"
                              RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <TranslateTransform X="0"
                                                    Y="0"/>
                            </Grid.RenderTransform>
                            <Border x:Name="ActiveBackground"
                                    Margin="2,2,8,2"
                                    Background="Transparent"
                                    CornerRadius="18"
                                    Opacity="0"/>
                            <Grid Margin="{TemplateBinding Padding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border x:Name="AccentDot"
                                        Width="12"
                                        Height="12"
                                        Margin="0,0,12,0"
                                        Background="{DynamicResource InfoCardAccentBrush}"
                                        CornerRadius="6"
                                        Opacity="0.3"
                                        VerticalAlignment="Center"/>

                                <ContentPresenter Grid.Column="1"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"/>

                                <Border x:Name="Underline"
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Width="0"
                                        Height="3"
                                        Margin="0,8,14,0"
                                        Background="{DynamicResource MenuButtonHoverBorderBrush}"
                                        CornerRadius="3"
                                        HorizontalAlignment="Left"
                                        Opacity="0"/>
                            </Grid>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTitleBrush}"/>
                                <Setter TargetName="AccentDot" Property="Opacity" Value="0.95"/>
                                <Setter TargetName="Underline" Property="Opacity" Value="1"/>
                                <Setter TargetName="Underline" Property="Width" Value="78"/>
                                <Setter TargetName="Underline" Property="Height" Value="4"/>
                                <Setter TargetName="ButtonRoot" Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform X="3"
                                                            Y="0"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTitleBrush}"/>
                                <Setter TargetName="AccentDot" Property="Opacity" Value="1"/>
                                <Setter TargetName="Underline" Property="Opacity" Value="1"/>
                                <Setter TargetName="Underline" Property="Width" Value="88"/>
                                <Setter TargetName="Underline" Property="Background" Value="{DynamicResource InfoCardAccentBrush}"/>
                                <Setter TargetName="ButtonRoot" Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform X="1"
                                                            Y="0"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="Tag" Value="Active">
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTitleBrush}"/>
                                <Setter TargetName="AccentDot" Property="Opacity" Value="1"/>
                                <Setter TargetName="AccentDot" Property="Background" Value="{DynamicResource PrimaryTitleBrush}"/>
                                <Setter TargetName="Underline" Property="Opacity" Value="1"/>
                                <Setter TargetName="Underline" Property="Width" Value="98"/>
                                <Setter TargetName="Underline" Property="Height" Value="4"/>
                                <Setter TargetName="Underline" Property="Background" Value="{DynamicResource PrimaryTitleBrush}"/>
                                <Setter TargetName="ActiveBackground" Property="Background" Value="{DynamicResource MenuButtonHoverBackgroundBrush}"/>
                                <Setter TargetName="ActiveBackground" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThemeSwitchButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource ThemeButtonForegroundBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ThemeButtonBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ThemeBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThemeBorder" Property="Background" Value="{DynamicResource MenuButtonHoverBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ThemeBorder" Property="Background" Value="{DynamicResource MenuButtonPressedBackgroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="315"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Margin="18"
                Background="{DynamicResource SidebarBrush}"
                CornerRadius="30"
                BorderBrush="{DynamicResource SidebarBorderBrush}"
                BorderThickness="1">
            <Grid Margin="28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="84"
                                Height="84"
                                Background="{DynamicResource LogoChipBackgroundBrush}"
                                CornerRadius="26"
                                BorderBrush="{DynamicResource LogoChipBorderBrush}"
                                BorderThickness="1"
                                HorizontalAlignment="Left">
                            <Image Source="logg.png"
                                   Width="64"
                                   Height="64"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="Fant"
                                   SnapsToDevicePixels="True"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1"
                                    Margin="16,10,0,0"
                                    VerticalAlignment="Top">
                            <TextBlock Text="Bienvenue,"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontSize="13"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="tinouille !"
                                       Margin="0,3,0,0"
                                       Foreground="{DynamicResource PrimaryTitleBrush}"
                                       FontSize="19"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Suivi des&#x0a;activités"
                               Margin="0,22,0,0"
                               Foreground="{DynamicResource PrimaryTitleBrush}"
                               FontSize="29"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Margin="0,38,0,0">
                    <Button Content="Vue générale"
                            x:Name="VueGeneraleButton"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="VueGenerale_Click"/>
                    <Button Content="Suivi des essais"
                            x:Name="SuiviEssaisButton"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="SuiviEssais_Click"/>
                </StackPanel>

                <Border Grid.Row="2"
                        Padding="18"
                        Background="{DynamicResource InfoCardBackgroundBrush}"
                        CornerRadius="22"
                        BorderBrush="{DynamicResource InfoCardBorderBrush}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Mode maquette"
                                   Foreground="{DynamicResource InfoCardAccentBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Les projets affichés sont des données mockées pour construire la vue générale."
                                   Margin="0,8,0,0"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontSize="15"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1"
              Margin="24,22,24,22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Margin="8,4,8,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="PageTitleText"
                               Text="Vue générale des projets"
                               FontSize="33"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTitleBrush}"/>
                    <TextBlock x:Name="PageSubtitleText"
                               Text="Les infos essentielles, en un coup d'oeil."
                               Margin="0,8,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="15"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Padding="18,12"
                            Background="{DynamicResource VersionBadgeBackgroundBrush}"
                            BorderBrush="{DynamicResource VersionBadgeBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="18"
                            VerticalAlignment="Center">
                        <TextBlock Text="Vers. 0.1"
                                   Foreground="{DynamicResource VersionBadgeForegroundBrush}"
                                   FontWeight="SemiBold"/>
                    </Border>

                    <Button x:Name="ThemeToggleButton"
                            Content="Blue pastel kawaii"
                            Style="{StaticResource ThemeSwitchButtonStyle}"
                            Click="ThemeToggle_Click"/>
                </StackPanel>
            </Grid>

            <Border Grid.Row="1"
                    Background="{DynamicResource ContentBackgroundBrush}"
                    CornerRadius="30"
                    Padding="18"
                    BorderBrush="{DynamicResource ContentBorderBrush}"
                    BorderThickness="1">
                <ContentControl x:Name="MainContent"/>
            </Border>
        </Grid>
    </Grid>
</Window>
